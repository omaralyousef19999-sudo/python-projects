  Widget _buildStatChip(String label, Color color) {
    return Container(
      padding: EdgeInsets.symmetric(horizontal: 12, vertical: 6),
      decoration: BoxDecoration(
        color: color.withOpacity(0.15),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: color.withOpacity(0.3)),
      ),
      child: Text(label, style: TextStyle(color: color, fontSize: 12, fontWeight: FontWeight.bold)),
    );
  }

  Color _getTypeColor(String type) {
    if (type == 'كارديو') return AppColors.hotOrange;
    if (type == 'قوة') return AppColors.neonGreen;
    if (type == 'HIIT') return AppColors.neonPink;
    if (type == 'يوغا') return AppColors.electricBlue;
    return AppColors.metallicGray;
  }

  IconData _getTypeIcon(String type) {
    if (type == 'كارديو') return Icons.favorite;
    if (type == 'قوة') return Icons.fitness_center;
    if (type == 'HIIT') return Icons.flash_on;
    if (type == 'يوغا') return Icons.self_improvement;
    return Icons.sports;
  }
}
