        'date': DateTime.now().toString(),
        'duration': exercise.duration,
        'caloriesBurned': exercise.duration * exercise.caloriesPerMinute,
      };
      currentUser.value!.exerciseHistory.add(entry);
      todayExerciseMinutes.value += exercise.duration;
      _saveUserData();
      Get.snackbar('🎉 أحسنت!', 'تم إكمال ${exercise.name}', backgroundColor: AppColors.successGreen);
    }
  }

  void addMealToHistory(Meal meal) {
    if (currentUser.value != null) {
      Map<String, dynamic> entry = {
        'mealId': meal.id,
        'name': meal.name,
        'date': DateTime.now().toString(),
        'calories': meal.calories,
      };
      currentUser.value!.mealHistory.add(entry);
      // FIX: تحديث السعرات في النموذج أيضاً
      todayCalories.value += meal.calories.toInt();
      currentUser.value!.dailyCaloriesConsumed = todayCalories.value.toDouble();
      _saveUserData();
      Get.snackbar('🍽️ تم التسجيل', 'تم إضافة ${meal.name}', backgroundColor: AppColors.electricBlue);
    }
  }

  void _saveUserData() async {
    if (currentUser.value != null) {
      SharedPreferences prefs = await SharedPreferences.getInstance();
      await prefs.setString('currentUser', jsonEncode(currentUser.value!.toJson()));

      String? usersJson = prefs.getString('users');
      if (usersJson != null) {
        List<dynamic> usersList = jsonDecode(usersJson);
        for (int i = 0; i < usersList.length; i++) {
          if (usersList[i]['id'] == currentUser.value!.id) {
            usersList[i] = currentUser.value!.toJson();
            break;
          }
        }
        await prefs.setString('users', jsonEncode(usersList));
      }
    }
  }

  // ========== حساب السعرات ==========
  int calculateCaloriesBurned(Exercise exercise) {
    if (currentUser.value == null) return exercise.duration * exercise.caloriesPerMinute;
    double weight = currentUser.value!.weight;
    double met = 0;

    if (exercise.type == 'كارديو') {
      met = 6.0;
    } else if (exercise.type == 'قوة') {
      met = 5.0;
    } else if (exercise.type == 'HIIT') {
      met = 8.0;
    } else if (exercise.type == 'يوغا') {
      met = 2.5;
    } else {
      met = 3.0;
    }

    return ((met * 3.5 * weight) / 200 * exercise.duration).toInt();
  }

  // ========== المدرب الصوتي ==========
  Future<void> speakCommand(String command) async {
    try {
      if (isSpeaking.value) {
        await flutterTts.stop();
      }
      await flutterTts.speak(command);
    } catch (e) {
      developer.log('خطأ في الصوت: $e'); // FIX
    }
  }

  void startWorkout(Exercise exercise) async {
    await speakCommand('بدأ التمرين: ${exercise.name}');
    await Future.delayed(Duration(seconds: 3));
    await speakCommand('استمر، أنت قوي!');
    await Future.delayed(Duration(seconds: 5));
    await speakCommand('راحة 10 ثواني');
    await Future.delayed(Duration(seconds: 10));
    await speakCommand('أكمل، أنت رائع!');
  }

  // ========== المساعد الذكي (Gemini API) ==========
  Future<void> askAI(String question) async {
    aiLoading.value = true;
    aiMessages.add({'sender': 'user', 'message': question});

    try {
      // محاكاة (بدون API حقيقي)
      String response = _getAIResponse(question);

      await Future.delayed(Duration(seconds: 1));
      aiMessages.add({'sender': 'ai', 'message': response});
      aiLoading.value = false;

      // نطق الرد
      await speakCommand(response);
    } catch (e) {
      aiMessages.add({'sender': 'ai', 'message': 'عذراً، حدث خطأ. حاول مرة أخرى.'});
      aiLoading.value = false;
    }
  }

  String _getAIResponse(String question) {
    String q = question.toLowerCase();
    if (q.contains('تمرين') || q.contains('رياضة')) {
      return 'أنصحك بتمارين HIIT لمدة 20 دقيقة، فهي ممتازة لحرق الدهون وبناء اللياقة.';
    } else if (q.contains('غذاء') || q.contains('أكل')) {
      return 'تناول وجبات غنية بالبروتين مثل الدجاج والسمك، مع الخضار الورقية والحبوب الكاملة.';
    } else if (q.contains('نوم')) {
      return 'احرص على النوم 7-8 ساعات يومياً لتحسين الأداء الرياضي وبناء العضلات.';
    } else if (q.contains('ماء')) {
      return 'اشرب 2-3 لتر من الماء يومياً، وزعها على مدار اليوم.';
    } else if (q.contains('وزن')) {
      return 'لإنقاص الوزن، ركز على تمارين الكارديو مع نظام غذائي متوازن يحتوي على سعرات حرارية أقل من احتياجك اليومي.';
    } else if (q.contains('عضلات')) {
      return 'للبناء العضلات، ركز على تمارين المقاومة مع زيادة البروتين في نظامك الغذائي.';
    } else {
      return 'مرحباً! أنا مساعدك الذكي للصحة واللياقة. اسألني عن التمارين، التغذية، النوم، أو أي سؤال صحي آخر.';
    }
  }

  // ========== الإشعارات ==========
  Future<void> sendLocalNotification(String title, String body) async {
    const AndroidNotificationDetails androidPlatformChannelSpecifics =
        AndroidNotificationDetails(
      'fitness_channel',
      'قناة اللياقة',
      importance: Importance.max,
      priority: Priority.high,
    );
    const NotificationDetails platformChannelSpecifics =
        NotificationDetails(android: androidPlatformChannelSpecifics);

    await flutterLocalNotificationsPlugin.show(
      0,
      title,
      body,
      platformChannelSpecifics,
    );
  }

  void scheduleDailyReminders() async {
    // تذكير للتمارين
    await Future.delayed(Duration(seconds: 5));
    await sendLocalNotification('🏋️ وقت التمرين!', 'حان وقت تمارينك اليومية، استعد للحركة!');

    await Future.delayed(Duration(seconds: 10));
    await sendLocalNotification('💧 اشرب الماء!', 'تذكر شرب كوب من الماء للحفاظ على الترطيب.');

    await Future.delayed(Duration(seconds: 15));
    await sendLocalNotification('🍽️ وقت الوجبة!', 'تناول وجبة صحية متوازنة الآن.');
  }

  // ========== مساعدة التنقل ==========
  void changePage(int index) {
    currentPage.value = index;
  }
}

