                Text('${controller.filteredMeals.length} وجبة', style: TextStyle(color: Colors.white)),
                Spacer(),
                Text('${controller.todayCalories.value} سعر/اليوم', style: TextStyle(color: AppColors.electricBlue)),
              ],
            );
          }),
          SizedBox(height: 12),

          // قائمة الوجبات
          Expanded(
            child: Obx(() {
              if (controller.filteredMeals.isEmpty) {
                return Center(child: Text('لا توجد وجبات مطابقة', style: TextStyle(color: AppColors.metallicGray)));
              }
              return ListView.builder(
                itemCount: controller.filteredMeals.length,
                itemBuilder: (context, index) {
                  Meal meal = controller.filteredMeals[index];
                  return _buildMealCard(meal);
                },
              );
            }),
          ),
        ],
      ),
    );
  }

  Widget _buildMealCard(Meal meal) {
    return Container(
      margin: EdgeInsets.only(bottom: 12),
      padding: EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppColors.darkCard,
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: AppColors.metallicGray),
      ),
      child: Row(
        children: [
          Container(
            padding: EdgeInsets.all(12),
            decoration: BoxDecoration(
              color: _getMealTypeColor(meal.type).withOpacity(0.1),
              borderRadius: BorderRadius.circular(12),
            ),
            child: Icon(_getMealTypeIcon(meal.type), color: _getMealTypeColor(meal.type)),
          ),
          SizedBox(width: 16),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(meal.name, style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
                Text('${meal.calories.toInt()} سعر • P:${meal.protein}g C:${meal.carbs}g F:${meal.fat}g',
                    style: TextStyle(color: AppColors.metallicGray, fontSize: 12)),
                if (meal.description.isNotEmpty)
                  Text(meal.description, style: TextStyle(color: AppColors.metallicGray, fontSize: 11)),
              ],
            ),
          ),
          GestureDetector(
            onTap: () {
              controller.addMealToHistory(meal);
            },
            child: Container(
              padding: EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(
                color: AppColors.neonGreen,
                borderRadius: BorderRadius.circular(12),
              ),
              child: Text('أضف', style: TextStyle(color: Colors.black, fontWeight: FontWeight.bold)),
            ),
          ),
        ],
      ),
    );
  }

  Color _getMealTypeColor(String type) {
    if (type == 'فطور') return AppColors.warningYellow;
    if (type == 'غداء') return AppColors.hotOrange;
    if (type == 'عشاء') return AppColors.electricBlue;
    return AppColors.neonPink;
  }

  IconData _getMealTypeIcon(String type) {
    if (type == 'فطور') return Icons.free_breakfast;
    if (type == 'غداء') return Icons.lunch_dining;
    if (type == 'عشاء') return Icons.dinner_dining;
    return Icons.cake;
  }
}

