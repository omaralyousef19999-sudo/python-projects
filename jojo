class Exercise {
  String id;
  String name;
  String type;
  String level;
  int duration;
  int rating;
  String bodyPart;
  String imageUrl;
  int caloriesPerMinute;
  List<String> steps;
  bool isCompleted;

  Exercise({
    required this.id,
    required this.name,
    required this.type,
    required this.level,
    required this.duration,
    required this.rating,
    required this.bodyPart,
    this.imageUrl = '',
    this.caloriesPerMinute = 5,
    this.steps = const [],
    this.isCompleted = false,
  });

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'name': name,
      'type': type,
      'level': level,
      'duration': duration,
      'rating': rating,
      'bodyPart': bodyPart,
      'imageUrl': imageUrl,
      'caloriesPerMinute': caloriesPerMinute,
      'steps': steps,
      'isCompleted': isCompleted,
    };
  }

  factory Exercise.fromJson(Map<String, dynamic> json) {
    return Exercise(
      id: json['id'],
      name: json['name'],
      type: json['type'],
      level: json['level'],
      duration: json['duration'],
      rating: json['rating'],
      bodyPart: json['bodyPart'],
      imageUrl: json['imageUrl'] ?? '',
      caloriesPerMinute: json['caloriesPerMinute'] ?? 5,
      steps: json['steps']?.cast<String>() ?? [],
      isCompleted: json['isCompleted'] ?? false,
    );
  }
}

