  // ========== تحميل البيانات ==========
  void _loadExercises() {
    List<Exercise> loaded = [];
    for (var data in allExercisesData) {
      loaded.add(Exercise.fromJson(data));
    }
    exercises.value = loaded;
    filteredExercises.value = loaded;
    _generateRecommendations();
  }

  void _loadMeals() {
    List<Meal> loaded = [];
    for (var data in allMealsData) {
      loaded.add(Meal.fromJson(data));
    }
    meals.value = loaded;
    filteredMeals.value = loaded;
  }

  void _loadUserData() {
    if (currentUser.value != null) {
      todaySteps.value = currentUser.value!.dailySteps;
      todayCalories.value = currentUser.value!.dailyCaloriesConsumed.toInt();
    }
  }

  void _generateRecommendations() {
    if (currentUser.value == null) {
      recommendedExercises.value = exercises.take(3).toList();
      return;
    }

    String goal = currentUser.value!.goal;
    String level = currentUser.value!.fitnessLevel;
    String? bodyPartNeeded;

    if (goal.contains('عضلات')) {
      bodyPartNeeded = 'الصدر';
    } else if (goal.contains('وزن')) {
      bodyPartNeeded = 'الأرجل';
    } else {
      bodyPartNeeded = 'الكامل';
    }

    List<Exercise> recommended = [];
    for (var exercise in exercises) {
      if (exercise.level == level || exercise.level == 'مبتدئ') {
        if (exercise.bodyPart == bodyPartNeeded || exercise.bodyPart == 'الكامل') {
          recommended.add(exercise);
        }
      }
    }

    if (recommended.length < 3) {
      recommended = exercises.take(3).toList();
    }
    recommendedExercises.value = recommended.take(3).toList();
  }

  // ========== فلاتر التمارين ==========
  void applyExerciseFilters() {
    List<Exercise> results = [];
    for (var exercise in exercises) {
      bool matchesSearch = true;
      bool matchesLevel = true;
      bool matchesType = true;
      bool matchesBodyPart = true;
      bool matchesDuration = true;
      bool matchesRating = true;

      if (searchQuery.value.isNotEmpty) {
        if (!exercise.name.contains(searchQuery.value)) {
          matchesSearch = false;
        }
      }

      if (selectedLevel.value != 'الكل') {
        if (exercise.level != selectedLevel.value) {
          matchesLevel = false;
        }
      }

      if (selectedType.value != 'الكل') {
        if (exercise.type != selectedType.value) {
          matchesType = false;
        }
      }

      if (selectedBodyPart.value != 'الكل') {
        if (exercise.bodyPart != selectedBodyPart.value) {
          matchesBodyPart = false;
        }
      }

      if (exercise.duration > durationRange.value) {
        matchesDuration = false;
      }

      if (ratingFilter.value > 0) {
        if (exercise.rating < ratingFilter.value) {
          matchesRating = false;
        }
      }

      if (matchesSearch && matchesLevel && matchesType && matchesBodyPart && matchesDuration && matchesRating) {
        results.add(exercise);
      }
    }
    filteredExercises.value = results;
  }

  void clearExerciseFilters() {
    searchQuery.value = '';
    selectedLevel.value = 'الكل';
    selectedType.value = 'الكل';
    selectedBodyPart.value = 'الكل';
    durationRange.value = 30;
    ratingFilter.value = 0;
    applyExerciseFilters();
  }

  // ========== فلاتر الوجبات ==========
  void applyMealFilters() {
    List<Meal> results = [];
    for (var meal in meals) {
      bool matchesSearch = true;
      bool matchesType = true;

      if (mealSearchQuery.value.isNotEmpty) {
        if (!meal.name.contains(mealSearchQuery.value)) {
          matchesSearch = false;
        }
      }

      if (selectedMealType.value != 'الكل') {
        if (meal.type != selectedMealType.value) {
          matchesType = false;
        }
      }

      if (matchesSearch && matchesType) {
        results.add(meal);
      }
    }
    filteredMeals.value = results;
  }

