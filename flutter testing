import 'package:flutter/material.dart';
import 'package:provider/provider.dart';

void main() {
  runApp(
    // ChangeNotifierProvider يغلف التطبيق بأكمله ليكون Provider متاحاً في كل الشاشات
    ChangeNotifierProvider(
      create: (context) => CartProvider(),
      child: const ShoppingApp(),
    ),
  );
}

// ========== التطبيق الرئيسي ==========
class ShoppingApp extends StatelessWidget {
  const ShoppingApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'سلة التسوق',
      theme: ThemeData(
        colorScheme: ColorScheme.fromSeed(seedColor: Colors.deepOrange),
        useMaterial3: true,
      ),
      home: const ProductsScreen(),
    );
  }
}

// ========== 1. الـ Provider (مخزن البيانات المركزي) ==========
class CartProvider extends ChangeNotifier {
  // قائمة المنتجات في السلة (كل منتج عبارة عن Map)
  List<Map<String, dynamic>> _cartItems = [];

  // getter: نعطي الشاشات حق القراءة فقط
  List<Map<String, dynamic>> get cartItems => _cartItems;

  // دالة لإضافة منتج إلى السلة
  void addToCart(Map<String, dynamic> product) {
    _cartItems.add(product);
    notifyListeners();  // 🔴 أهم سطر: يخبر كل الشاشات بأن البيانات تغيرت
  }

  // دالة لإزالة منتج من السلة
  void removeFromCart(int index) {
    _cartItems.removeAt(index);
    notifyListeners();  // تحديث كل الشاشات
  }

  // دالة لحساب المجموع الكلي
  double get totalPrice {
    double total = 0;
    for (var item in _cartItems) {
      total += item['price'] as double;
    }
    return total;
  }

  // دالة لتفريغ السلة
  void clearCart() {
    _cartItems.clear();
    notifyListeners();
  }
}

// ========== 2. شاشة عرض المنتجات (قائمة طعام) ==========
class ProductsScreen extends StatelessWidget {
  const ProductsScreen({super.key});

  // قائمة المنتجات المتاحة للشراء
  final List<Map<String, dynamic>> products = const [
    {'name': '🍕 بيتزا', 'price': 25.0, 'description': 'بيتزا عائلية بالجبن'},
    {'name': '🍔 برغر', 'price': 15.0, 'description': 'برغر لحم مع بطاطا'},
    {'name': '🥗 سلطة', 'price': 10.0, 'description': 'سلطة يونانية طازجة'},
    {'name': '🥤 كوكا كولا', 'price': 5.0, 'description': 'مشروب غازي مثلج'},
    {'name': '🍰 تشيز كيك', 'price': 12.0, 'description': 'تشيز كيك بصلصة الفراولة'},
  ];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('🛍️ المتجر'),
        backgroundColor: Colors.deepOrange,
        foregroundColor: Colors.white,
        actions: [
          // أيقونة سلة التسوق تظهر عدد المنتجات
          Consumer<CartProvider>(
            builder: (context, cart, child) {
              return Stack(
                children: [
                  IconButton(
                    onPressed: () {
                      Navigator.push(
                        context,
                        MaterialPageRoute(builder: (context) => const CartScreen()),
                      );
                    },
                    icon: const Icon(Icons.shopping_cart),
                  ),
                  if (cart.cartItems.isNotEmpty)
                    Positioned(
                      right: 0,
                      top: 0,
                      child: Container(
                        padding: const EdgeInsets.all(2),
                        decoration: BoxDecoration(
                          color: Colors.red,
                          borderRadius: BorderRadius.circular(10),
                        ),
                        constraints: const BoxConstraints(minWidth: 16, minHeight: 16),
                        child: Text(
                          '${cart.cartItems.length}',
                          style: const TextStyle(color: Colors.white, fontSize: 10),
                          textAlign: TextAlign.center,
                        ),
                      ),
                    ),
                ],
              );
            },
          ),
        ],
      ),
      body: ListView.builder(
        itemCount: products.length,
        itemBuilder: (context, index) {
          final product = products[index];
          return Card(
            margin: const EdgeInsets.all(8),
            child: ListTile(
              leading: Text(product['name']!, style: const TextStyle(fontSize: 30)),
              title: Text(product['name']!),
              subtitle: Text('\$${product['price']}'),
              trailing: ElevatedButton(
                onPressed: () {
                  // إضافة المنتج إلى السلة عبر Provider
                  Provider.of<CartProvider>(context, listen: false).addToCart(product);
                  // رسالة تأكيد
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(content: Text('تمت إضافة ${product['name']} إلى السلة')),
                  );
                },
                child: const Text('أضف'),
              ),
            ),
          );
        },
      ),
    );
  }
}

// ========== 3. شاشة سلة التسوق ==========
class CartScreen extends StatelessWidget {
  const CartScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('🛒 سلة التسوق'),
        backgroundColor: Colors.deepOrange,
        foregroundColor: Colors.white,
      ),
      body: Consumer<CartProvider>(
        builder: (context, cart, child) {
          if (cart.cartItems.isEmpty) {
            return const Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(Icons.shopping_cart_outlined, size: 80, color: Colors.grey),
                  SizedBox(height: 16),
                  Text('سلتك فارغة', style: TextStyle(fontSize: 20, color: Colors.grey)),
                ],
              ),
            );
          }

          return Column(
            children: [
              Expanded(
                child: ListView.builder(
                  itemCount: cart.cartItems.length,
                  itemBuilder: (context, index) {
                    final item = cart.cartItems[index];
                    return ListTile(
                      leading: Text(item['name']!, style: const TextStyle(fontSize: 24)),
                      title: Text(item['name']!),
                      subtitle: Text('\$${item['price']}'),
                      trailing: IconButton(
                        icon: const Icon(Icons.delete, color: Colors.red),
                        onPressed: () {
                          cart.removeFromCart(index);
                        },
                      ),
                    );
                  },
                ),
              ),
              Container(
                padding: const EdgeInsets.all(16),
                decoration: BoxDecoration(
                  color: Colors.grey[200],
                  borderRadius: const BorderRadius.vertical(top: Radius.circular(20)),
                ),
                child: Row(
                  mainAxisAlignment: MainAxisAlignment.spaceBetween,
                  children: [
                    Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        const Text('المجموع الكلي', style: TextStyle(fontSize: 16)),
                        Text(
                          '\$${cart.totalPrice.toStringAsFixed(2)}',
                          style: const TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
                        ),
                      ],
                    ),
                    ElevatedButton.icon(
                      onPressed: () {
                        cart.clearCart();
                        ScaffoldMessenger.of(context).showSnackBar(
                          const SnackBar(content: Text('تم إفراغ السلة')),
                        );
                      },
                      icon: const Icon(Icons.delete_sweep),
                      label: const Text('إفراغ السلة'),
                      style: ElevatedButton.styleFrom(backgroundColor: Colors.red),
                    ),
                  ],
                ),
              ),
            ],
          );
        },
      ),
    );
  }
}
