    def generate_demo_knockout_matches(self):
        stage = self.k_stage_combo.currentText()
        teams = get_teams()
        if len(teams) < 2:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error",
                                "لا يوجد فرق كافية" if self.lang=="ar" else "Not enough teams")
            return
        random.shuffle(teams)
        pairs = []
        for i in range(0, min(len(teams)//2*2, 16), 2):
            pairs.append((teams[i], teams[i+1]))
        for h, a in pairs:
            add_match(h, a, random.randint(0,4), random.randint(0,4),
                      QDate.currentDate().toString("yyyy-MM-dd"), stage)
        QMessageBox.information(self, "تم" if self.lang=="ar" else "Done",
                                "تم توليد مباريات افتراضية" if self.lang=="ar" else "Demo matches generated")
        self.populate_knockout_table()

