        layout = QFormLayout(dlg)
        h = QComboBox(); h.addItems(get_teams())
        a = QComboBox(); a.addItems(get_teams())
        hg = QSpinBox(); hg.setRange(0,20)
        ag = QSpinBox(); ag.setRange(0,20)
        stage = QComboBox(); stage.addItems(["Round of 16","Quarter Final","Semi Final","Final"])
        layout.addRow("المضيف:" if self.lang=="ar" else "Home:", h)
        layout.addRow("أهدافه:" if self.lang=="ar" else "Home Goals:", hg)
        layout.addRow("الضيف:" if self.lang=="ar" else "Away:", a)
        layout.addRow("أهدافه:" if self.lang=="ar" else "Away Goals:", ag)
        layout.addRow("الجولة:" if self.lang=="ar" else "Stage:", stage)
        btn = QPushButton("إضافة" if self.lang=="ar" else "Add")
        btn.clicked.connect(lambda: (add_match(h.currentText(), a.currentText(), hg.value(), ag.value(),
                                              QDate.currentDate().toString("yyyy-MM-dd"), stage.currentText()),
                                     self.populate_knockout_table(), dlg.accept()))
        layout.addRow("", btn)
        dlg.exec()

