    def update_table(self):
        df = get_standings()
        if df.empty:
            self.table.setRowCount(0)
            self.table.setColumnCount(0)
            return
        h = ["الفريق","لعب","ف","ت","خ","له","عليه","فارق","نقاط"] if self.lang=="ar" else ["Team","P","W","D","L","GF","GA","GD","Pts"]
        self.table.setColumnCount(9)
        self.table.setHorizontalHeaderLabels(h)
        self.table.setRowCount(len(df))
        for i, r in df.iterrows():
            for j, v in enumerate([r["name"],r["P"],r["W"],r["D"],r["L"],r["GF"],r["GA"],r["GD"],r["Pts"]]):
                item = QTableWidgetItem(str(v))
                if i<4: item.setBackground(QColor(0,120,215,100))
                self.table.setItem(i,j,item)
        self.table.resizeColumnsToContents()

