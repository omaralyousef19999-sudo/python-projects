    def update_table(self):
        try:
            df = get_standings()
            if df.empty:
                self.table.setRowCount(0)
                self.table.setColumnCount(0)
                return

            headers_ar = ["المركز", "الفريق", "الدولة", "المجموعة", "لعب", "ف", "ت", "خ", "له", "عليه", "فارق", "نقاط", "الحالة"]
            headers_en = ["Pos", "Team", "Country", "Group", "P", "W", "D", "L", "GF", "GA", "GD", "Pts", "Status"]

            headers = headers_ar if self.lang == "ar" else headers_en

            self.table.setColumnCount(len(headers))
            self.table.setHorizontalHeaderLabels(headers)
            self.table.setRowCount(len(df))

            for i, row in df.iterrows():
                data = [
                    i + 1,  # المركز
                    row["name"], 
                    row["country"], 
                    row["group_char"],
                    row["P"], row["W"], row["D"], row["L"],
                    row["GF"], row["GA"], row["GD"], row["Pts"],
                    "مقصي" if row.get("eliminated", 0) else "نشط"
                ]

                for col, value in enumerate(data):
                    item = QTableWidgetItem(str(value))
                    item.setTextAlignment(Qt.AlignmentFlag.AlignCenter)

                    # تلوين الصفوف حسب المركز والحالة
                    if row.get("eliminated", 0):
                        item.setBackground(QColor(255, 100, 100, 180))  # أحمر للفرق المقصية
                    elif i == 0:
                        item.setBackground(QColor(255, 215, 0, 200))  # ذهبي للمركز الأول
                        item.setForeground(QColor(0, 0, 0))
                        item.setFont(QFont("Arial", 16, QFont.Weight.Bold))
                    elif i < 8:
                        item.setBackground(QColor(0, 100, 200, 150))  # أزرق للمراكز المتقدمة
                    elif i < 16:
                        item.setBackground(QColor(100, 150, 255, 120))  # أزرق فاتح
                    else:
                        item.setBackground(QColor(200, 200, 200, 100))  # رمادي للفرق المتأخرة

                    self.table.setItem(i, col, item)

            self.table.resizeColumnsToContents()
        except Exception as e:
            print(f"Error in update_table: {e}")

