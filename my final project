    def draw_chart(self):
        try:
            df = get_standings().head(12)
            if df.empty:
                return

            self.canvas.figure.clear()
            ax = self.canvas.figure.add_subplot(111)

            teams_raw = df["name_ar"].tolist() if self.lang == "ar" else df["name_en"].tolist()
            points = df["Pts"].tolist()
            eliminated = df.get("eliminated", [0] * len(df)).tolist()
            banned = df.get("banned", [0] * len(df)).tolist()

            teams = []
            colors = []
            for i, team in enumerate(teams_raw):
                teams.append(team)
                
                # لون مختلف للفرق المحظورة والمقصية
                if banned[i]:
                    colors.append("#8B0000")  # أحمر غامق للفرق المحظورة
                elif eliminated[i]:
                    colors.append("#FF6B6B")  # أحمر للفرق المقصية
                else:
                    colors.append("#1E90FF")  # أزرق للفرق النشطة

            bars = ax.barh(range(len(teams)), points, color=colors, height=0.7)
            ax.set_facecolor("#001f3f")
            self.canvas.figure.patch.set_facecolor("#001f3f")

            ax.set_yticks(range(len(teams)))
            ax.set_yticklabels(teams, fontsize=14, fontweight='bold', color='white')
            ax.tick_params(colors="white", labelsize=12)
            ax.set_xlabel("النقاط" if self.lang=="ar" else "Points", color="white", fontsize=14)
            ax.set_title("أفضل 12 فريق" if self.lang=="ar" else "Top 12 Teams",
                         color="#E6F0FF", fontsize=20, fontweight="bold", pad=18)

            ax.invert_yaxis()
            ax.grid(True, axis='x', color='gray', alpha=0.3, linestyle='--')

            for i, pt in enumerate(points):
                ax.text(pt + 0.3, i, str(pt), va='center', ha='left', color="white", fontweight='bold', fontsize=12)

            plt.subplots_adjust(left=0.35, right=0.95, top=0.88, bottom=0.12)
            self.canvas.draw()
        except Exception as e:
            print(f"Error in draw_chart: {e}")

