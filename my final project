    def generate_demo_knockout_matches(self):
        """توليد مباريات افتراضية للإقصائيات - الإصدار المعدل والمؤكد"""
        try:
            # الحصول على الفرق المتاحة
            teams_df = get_teams()
            
            if teams_df.empty or len(teams_df) < 2:
                QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", 
                    "لا يوجد فرق كافية لتوليد المباريات" if self.lang=="ar" else "Not enough teams to generate matches")
                return
            
            stage = self.k_stage_combo.currentText()
            
            # استخدام الأسماء العربية للتأكد من التوافق مع قاعدة البيانات
            available_teams = teams_df["name_ar"].tolist()
            
            if len(available_teams) < 8:
                QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error",
                    "يحتاج إلى 8 فرق على الأقل لتوليد مباريات الإقصائيات" if self.lang=="ar" 
                    else "Need at least 8 teams to generate knockout matches")
                return
            
            # استخدام أول 8 فرق فقط
            selected_teams = available_teams[:8]
            
            # خلط الفرق عشوائياً
            random.shuffle(selected_teams)
            
            match_count = 0
            
            # إنشاء 4 أزواج من المباريات (ذهاب وإياب)
            for i in range(4):
                pair_id = 1000 + i  # معرف زوجي فريد
                
                # الفريق المضيف والضيف
                home_team = selected_teams[i * 2]
                away_team = selected_teams[i * 2 + 1]
                
                # تواريخ المباريات
                first_leg_date = QDate.currentDate().addDays(i * 7).toString("yyyy-MM-dd")
                second_leg_date = QDate.currentDate().addDays(i * 7 + 14).toString("yyyy-MM-dd")
                
                # نتائج عشوائية واقعية
                home_goals_1 = random.randint(0, 3)
                away_goals_1 = random.randint(0, 2)
                away_goals_2 = random.randint(0, 3)
                home_goals_2 = random.randint(0, 2)
                
                # إضافة مباراة الذهاب
                success1 = add_match(home_team, away_team, home_goals_1, away_goals_1, 
                                   first_leg_date, stage, 'first', pair_id)
                
                # إضافة مباراة الإياب
                success2 = add_match(away_team, home_team, away_goals_2, home_goals_2, 
                                   second_leg_date, stage, 'second', pair_id)
                
                if success1 and success2:
                    match_count += 2
            
            if match_count > 0:
                QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                    f"تم توليد {match_count} مباراة تجريبية بنجاح" if self.lang=="ar" 
                    else f"Successfully generated {match_count} demo matches")
                
                # تحديث الجدول وعرض النتائج
                self.populate_knockout_table()
                self.update_qualified_teams()
            else:
                QMessageBox.warning(self, "تحذير" if self.lang=="ar" else "Warning",
                    "لم يتم إضافة أي مباريات" if self.lang=="ar" else "No matches were added")
                
        except Exception as e:
            print(f"خطأ مفصل في generate_demo_knockout_matches: {str(e)}")
            print(f"تفاصيل الخطأ: {traceback.format_exc()}")
            
            QMessageBox.critical(self, "خطأ" if self.lang=="ar" else "Error", 
                f"حدث خطأ أثناء توليد المباريات: {str(e)}" if self.lang=="ar" 
                else f"Error generating matches: {str(e)}")

