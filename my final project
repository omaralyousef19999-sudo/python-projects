def get_standings():
    conn = sqlite3.connect(DB_PATH)
    try:
        query = """
        SELECT t.name_ar, t.name_en, t.country_ar, t.country_en, t.group_char, t.eliminated, t.banned,
               COUNT(m.id) AS P,
               SUM(CASE WHEN (m.home_team = t.name_ar AND m.home_goals > m.away_goals) OR 
                             (m.away_team = t.name_ar AND m.away_goals > m.home_goals) THEN 1 ELSE 0 END) AS W,
               SUM(CASE WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS D,
               SUM(CASE WHEN (m.home_team = t.name_ar AND m.home_goals < m.away_goals) OR 
                             (m.away_team = t.name_ar AND m.away_goals < m.home_goals) THEN 1 ELSE 0 END) AS L,
               COALESCE(SUM(CASE WHEN m.home_team = t.name_ar THEN m.home_goals ELSE m.away_goals END), 0) AS GF,
               COALESCE(SUM(CASE WHEN m.home_team = t.name_ar THEN m.away_goals ELSE m.home_goals END), 0) AS GA,
               (COALESCE(SUM(CASE WHEN m.home_team = t.name_ar THEN m.home_goals ELSE m.away_goals END), 0) -
                COALESCE(SUM(CASE WHEN m.home_team = t.name_ar THEN m.away_goals ELSE m.home_goals END), 0)) AS GD,
               SUM(CASE WHEN (m.home_team = t.name_ar AND m.home_goals > m.away_goals) OR 
                            (m.away_team = t.name_ar AND m.away_goals > m.home_goals) THEN 3
                    WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS Pts
        FROM teams t LEFT JOIN matches m ON m.home_team = t.name_ar OR m.away_team = t.name_ar
        GROUP BY t.name_ar
        ORDER BY Pts DESC, GD DESC, GF DESC
        """
        df = pd.read_sql_query(query, conn)
        return df
    except Exception as e:
        print(f"Error in get_standings: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

def get_matches(stage=None):
    conn = sqlite3.connect(DB_PATH)
    try:
        if stage:
            df = pd.read_sql_query("SELECT * FROM matches WHERE stage = ? ORDER BY date, home_team", conn, params=(stage,))
        else:
            df = pd.read_sql_query("SELECT * FROM matches ORDER BY date, home_team", conn)
        return df
    except Exception as e:
        print(f"Error in get_matches: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

def eliminate_teams(team_names):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # إعادة تعيين جميع الفرق أولاً
        c.execute("UPDATE teams SET eliminated = 0")
        # ثم إقصاء الفرق المحددة
        for team in team_names:
            c.execute("UPDATE teams SET eliminated = 1 WHERE name_ar = ? OR name_en = ?", (team, team))
        conn.commit()
    except Exception as e:
        print(f"Error in eliminate_teams: {e}")
    finally:
        conn.close()

def ban_team(team_name, ban_status):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("UPDATE teams SET banned = ? WHERE name_ar = ? OR name_en = ?", (ban_status, team_name, team_name))
        conn.commit()
    except Exception as e:
        print(f"Error in ban_team: {e}")
    finally:
        conn.close()

def delete_team(team_name):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # حذف المباريات المرتبطة أولاً
        c.execute("DELETE FROM matches WHERE home_team = ? OR away_team = ?", (team_name, team_name))
        # ثم حذف الفريق
        c.execute("DELETE FROM teams WHERE name_ar = ? OR name_en = ?", (team_name, team_name))
        conn.commit()
        return True
    except Exception as e:
        print(f"Error in delete_team: {e}")
        return False
    finally:
        conn.close()

def delete_match(match_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("DELETE FROM matches WHERE id = ?", (match_id,))
        conn.commit()
        return True
    except Exception as e:
        print(f"Error in delete_match: {e}")
        return False
    finally:
        conn.close()

def reset_tournament():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("DELETE FROM matches")
        c.execute("UPDATE teams SET eliminated = 0, banned = 0")
        conn.commit()
    except Exception as e:
        print(f"Error in reset_tournament: {e}")
    finally:
        conn.close()

def get_knockout_pairs(stage):
    conn = sqlite3.connect(DB_PATH)
    try:
        df = pd.read_sql_query("""
            SELECT DISTINCT knockout_pair_id, home_team, away_team 
            FROM matches 
            WHERE stage = ? AND knockout_pair_id > 0 
            ORDER BY knockout_pair_id
        """, conn, params=(stage,))
        return df
    except Exception as e:
        print(f"Error in get_knockout_pairs: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

def get_qualified_teams():
    """الحصول على الفرق المتأهلة للإقصائيات (أفضل 16 فريق)"""
    standings = get_standings()
