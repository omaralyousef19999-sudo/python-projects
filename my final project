    # ---------- وظائف التصدير ----------
    def export_both(self):
        ok1 = self.export_pdf(save_dialog=False)
        ok2 = self.export_docx(save_dialog=False)
        if ok1 and ok2:
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", "تم تصدير PDF و Word بنجاح" if self.lang=="ar" else "Exported PDF and Word successfully")
        else:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "حدث خطأ أثناء التصدير" if self.lang=="ar" else "Export error occurred")

    def export_pdf(self, save_dialog=True):
        if SimpleDocTemplate is None:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "مكتبة reportlab غير مثبتة. الرجاء تثبيتها عبر pip install reportlab" if self.lang=="ar" else "reportlab not installed. Please pip install reportlab")
            return False

        # حدد مكان الحفظ
        default_name = f"UCL_Export_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf"
        fname = QFileDialog.getSaveFileName(self, "حفظ PDF" if self.lang=="ar" else "Save PDF", default_name, "PDF Files (*.pdf)")[0] if save_dialog else default_name
        if not fname:
            return False

        # حفظ مخطط كصورة مؤقتة
        tmp_img = tempfile.NamedTemporaryFile(suffix=".png", delete=False)
        try:
            # رسم الحقل الحالي وحفظه
            df = get_standings().head(12)
            fig = plt.figure(figsize=(11,6))
            ax = fig.add_subplot(111)
            if not df.empty:
                teams_raw = df["name"].tolist()
                points = df["Pts"].tolist()
                teams = []
                for team in teams_raw:
                    if any(ord(c) >= 0x0600 for c in team):
                        teams.append(team[::-1])
                    else:
                        teams.append(team)
                ax.barh(range(len(teams)), points, color="#1E90FF", height=0.7)
                ax.set_yticks(range(len(teams)))
                ax.set_yticklabels(teams, fontsize=10)
                ax.invert_yaxis()
                ax.set_xlabel("Points")
            fig.tight_layout()
            fig.savefig(tmp_img.name, dpi=150, facecolor=fig.get_facecolor())
            plt.close(fig)

            # إعداد PDF
            doc = SimpleDocTemplate(fname, pagesize=A4)
            styles = getSampleStyleSheet()
            story = []
            title_style = ParagraphStyle('title', parent=styles['Heading1'], alignment=1, fontSize=18, textColor=rlcolors.HexColor("#003f7f"))
            normal_center = ParagraphStyle('normal_center', parent=styles['Normal'], alignment=1)
            story.append(Paragraph("UEFA Champions League - Export", title_style))
            story.append(Spacer(1, 12))

            # أيقونة/شعار لو وجد
            if Path("fifa.ico").exists():
                try:
                    # reportlab يفضل صور بصيغ png/jpg، لذا إن كانت ico لا تعمل يمكن تجاهلها
                    story.append(Paragraph(" ", normal_center))
                except:
                    pass

            story.append(Paragraph(f"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}", styles['Normal']))
            story.append(Spacer(1, 12))

            # جدول الترتيب
            st_df = get_standings()
            if not st_df.empty:
                story.append(Paragraph("Standings / الترتيب", styles['Heading2']))
                table_data = [[c for c in ["Team","P","W","D","L","GF","GA","GD","Pts"]]]
                for _, r in st_df.iterrows():
                    table_data.append([r["name"], int(r["P"]), int(r["W"]), int(r["D"]), int(r["L"]), int(r["GF"]), int(r["GA"]), int(r["GD"]), int(r["Pts"])])
                tbl = RLTable(table_data, repeatRows=1)
                tbl.setStyle(TableStyle([
                    ('BACKGROUND', (0,0), (-1,0), rlcolors.HexColor("#1E90FF")),
                    ('TEXTCOLOR', (0,0), (-1,0), rlcolors.white),
                    ('GRID', (0,0), (-1,-1), 0.25, rlcolors.gray),
                    ('ALIGN', (1,1), (-1,-1), 'CENTER'),
                ]))
                story.append(tbl)
                story.append(Spacer(1, 12))

            # جميع المباريات
            mdf = get_matches()
            if not mdf.empty:
                story.append(Paragraph("Matches / المباريات", styles['Heading2']))
                # سنعرض جدول بسيط (قد يكون طويلاً)
                table_data = [[ "Date","Stage","Home","Away","HG","AG" ]]
                for _, r in mdf.iterrows():
                    table_data.append([r["date"], r["stage"], r["home_team"], r["away_team"], str(r["home_goals"]), str(r["away_goals"])])
                tbl2 = RLTable(table_data, repeatRows=1, colWidths=[60,90,150,150,30,30])
                tbl2.setStyle(TableStyle([
                    ('BACKGROUND', (0,0), (-1,0), rlcolors.HexColor("#87CEFA")),
                    ('GRID', (0,0), (-1,-1), 0.25, rlcolors.gray),
                ]))
                story.append(tbl2)
                story.append(Spacer(1, 12))

            # إضافة الرسم كصورة
            story.append(Paragraph("Chart", styles['Heading2']))
            story.append(Spacer(1,6))
            story.append(RLImage(tmp_img.name, width=450, height=220))
            story.append(Spacer(1,12))

            doc.build(story)
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", f"تم حفظ PDF: {fname}" if self.lang=="ar" else f"PDF saved: {fname}")
            return True
        except Exception as e:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", f"Failed to export PDF: {e}")
            return False
        finally:
            try:
                tmp_img.close()
                os.unlink(tmp_img.name)
            except:
                pass

    def export_docx(self, save_dialog=True):
        if Document is None:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "مكتبة python-docx غير مثبتة. الرجاء تثبيتها عبر pip install python-docx" if self.lang=="ar" else "python-docx not installed. Please pip install python-docx")
            return False

        default_name = f"UCL_Export_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"
        fname = QFileDialog.getSaveFileName(self, "حفظ Word" if self.lang=="ar" else "Save Word", default_name, "Word Files (*.docx)")[0] if save_dialog else default_name
        if not fname:
            return False
        try:
            doc = Document()
            doc.add_heading('UEFA Champions League - Export', 0)
            doc.add_paragraph(f"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
            doc.add_paragraph(" ")

            # جدول الترتيب
            st_df = get_standings()
            if not st_df.empty:
                doc.add_heading('Standings / الترتيب', level=1)
                table = doc.add_table(rows=1, cols=9)
                hdr_cells = table.rows[0].cells
                hdrs = ["Team","P","W","D","L","GF","GA","GD","Pts"]
                for i, h in enumerate(hdrs):
                    hdr_cells[i].text = h
                for _, r in st_df.iterrows():
                    row_cells = table.add_row().cells
                    row_cells[0].text = str(r["name"])
                    row_cells[1].text = str(int(r["P"]))
                    row_cells[2].text = str(int(r["W"]))
                    row_cells[3].text = str(int(r["D"]))
                    row_cells[4].text = str(int(r["L"]))
                    row_cells[5].text = str(int(r["GF"]))
                    row_cells[6].text = str(int(r["GA"]))
                    row_cells[7].text = str(int(r["GD"]))
                    row_cells[8].text = str(int(r["Pts"]))
                doc.add_paragraph(" ")

            # جميع المباريات
            mdf = get_matches()
            if not mdf.empty:
                doc.add_heading('Matches / المباريات', level=1)
                table2 = doc.add_table(rows=1, cols=6)
                hdr = table2.rows[0].cells
                headers = ["Date","Stage","Home","Away","HG","AG"]
                for i, h in enumerate(headers):
                    hdr[i].text = h
                for _, r in mdf.iterrows():
                    row = table2.add_row().cells
                    row[0].text = str(r["date"])
                    row[1].text = str(r["stage"])
                    row[2].text = str(r["home_team"])
                    row[3].text = str(r["away_team"])
                    row[4].text = str(r["home_goals"])
                    row[5].text = str(r["away_goals"])
                doc.add_paragraph(" ")

            # إضافة المخطط (نفس الطريقة: نرسم ونحفظ صورة مؤقتة ثم ندرجها)
            tmp_img = tempfile.NamedTemporaryFile(suffix=".png", delete=False)
            try:
                df = get_standings().head(12)
                fig = plt.figure(figsize=(11,6))
                ax = fig.add_subplot(111)
                if not df.empty:
                    teams_raw = df["name"].tolist()
                    points = df["Pts"].tolist()
                    teams = []
                    for team in teams_raw:
                        if any(ord(c) >= 0x0600 for c in team):
                            teams.append(team[::-1])
                        else:
                            teams.append(team)
                    ax.barh(range(len(teams)), points, color="#1E90FF", height=0.7)
                    ax.set_yticks(range(len(teams)))
                    ax.set_yticklabels(teams, fontsize=10)
                    ax.invert_yaxis()
                    ax.set_xlabel("Points")
                fig.tight_layout()
                fig.savefig(tmp_img.name, dpi=150, facecolor=fig.get_facecolor())
                plt.close(fig)
                doc.add_heading('Chart', level=1)
                doc.add_picture(tmp_img.name, width=Inches(6))
            finally:
                try:
                    tmp_img.close()
                    os.unlink(tmp_img.name)
                except:
                    pass

            doc.save(fname)
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", f"تم حفظ Word: {fname}" if self.lang=="ar" else f"Word saved: {fname}")
            return True
        except Exception as e:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", f"Failed to export Word: {e}")
            return False

