    def advance_stage(self):
        current_stage = self.k_stage_combo.currentText()
        next_stage = ""
        
        if current_stage == "Round of 16":
            next_stage = "Quarter Final"
            teams_to_keep = 8
        elif current_stage == "Quarter Final":
            next_stage = "Semi Final"
            teams_to_keep = 4
        elif current_stage == "Semi Final":
            next_stage = "Final"
            teams_to_keep = 2
        else:
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                "البطولة انتهت!" if self.lang=="ar" else "Tournament finished!")
            return
        
        # الحصول على الفرق المتأهلة (الفرق التي لديها نقاط أكثر)
        standings = get_standings()
        qualified_teams = standings.head(teams_to_keep)["name"].tolist()
        
        # إقصاء الفرق الأخرى
        all_teams = get_all_teams()["name"].tolist()
        eliminated_teams = [team for team in all_teams if team not in qualified_teams]
        eliminate_teams(eliminated_teams)
        
        QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
            f"تم التقدم ل{next_stage}. الفرق المتأهلة: {', '.join(qualified_teams)}" if self.lang=="ar" 
            else f"Advanced to {next_stage}. Qualified teams: {', '.join(qualified_teams)}")
        
        self.k_stage_combo.setCurrentText(next_stage)
        self.refresh_ui()

