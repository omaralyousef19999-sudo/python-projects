    def generate_demo_knockout_matches(self):
        # مثال سريع لتوليد مباريات - يستخدم الفرق المتاحة
        teams = get_teams()
        if len(teams) < 2:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "لا يوجد فرق كافية" if self.lang=="ar" else "Not enough teams")
            return
        # نأخذ أزواج عشوائية (بسيط)
        import random
        random.shuffle(teams)
        pairs = []
        for i in range(0, min(8, len(teams)//2*2), 2):  # لنولد حتى 4 مباريات مبدئياً (مثال)
            pairs.append((teams[i], teams[i+1]))
        for h,a in pairs:
            add_match(h, a, random.randint(0,4), random.randint(0,4), QDate.currentDate().toString("yyyy-MM-dd"), self.k_stage_combo.currentText())
        QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", "تم توليد مباريات تجريبية" if self.lang=="ar" else "Demo matches generated")
        self.populate_knockout_table()

