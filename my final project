def add_team(name, country, group):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("INSERT INTO teams (name, country, group_char) VALUES (?, ?, ?)", (name, country, group))
        conn.commit()
        return True
    except sqlite3.IntegrityError:
        return False
    finally:
        conn.close()

def add_match(home, away, hg, ag, date, stage, leg='single', pair_id=0):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("""INSERT INTO matches (home_team, away_team, home_goals, away_goals, date, stage, leg, knockout_pair_id)
                 VALUES (?, ?, ?, ?, ?, ?, ?, ?)""",
              (home, away, hg, ag, date, stage, leg, pair_id))
    conn.commit()
    conn.close()

def get_teams(include_eliminated=False):
    conn = sqlite3.connect(DB_PATH)
    try:
        if include_eliminated:
            df = pd.read_sql_query("SELECT name FROM teams ORDER BY name", conn)
        else:
            df = pd.read_sql_query("SELECT name FROM teams WHERE eliminated = 0 ORDER BY name", conn)
        return df["name"].tolist()
    except Exception as e:
        print(f"Error in get_teams: {e}")
        return []
    finally:
        conn.close()

def get_all_teams():
    conn = sqlite3.connect(DB_PATH)
    try:
        df = pd.read_sql_query("SELECT name, country, group_char, eliminated FROM teams ORDER BY name", conn)
        return df
    except Exception as e:
        print(f"Error in get_all_teams: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

def get_standings():
    conn = sqlite3.connect(DB_PATH)
    try:
        query = """
        SELECT t.name, t.country, t.group_char, t.eliminated,
               COUNT(m.id) AS P,
               SUM(CASE WHEN (m.home_team = t.name AND m.home_goals > m.away_goals) OR 
                             (m.away_team = t.name AND m.away_goals > m.home_goals) THEN 1 ELSE 0 END) AS W,
               SUM(CASE WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS D,
               SUM(CASE WHEN (m.home_team = t.name AND m.home_goals < m.away_goals) OR 
                             (m.away_team = t.name AND m.away_goals < m.home_goals) THEN 1 ELSE 0 END) AS L,
               COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.home_goals ELSE m.away_goals END), 0) AS GF,
               COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.away_goals ELSE m.home_goals END), 0) AS GA,
               (COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.home_goals ELSE m.away_goals END), 0) -
                COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.away_goals ELSE m.home_goals END), 0)) AS GD,
               SUM(CASE WHEN (m.home_team = t.name AND m.home_goals > m.away_goals) OR 
                            (m.away_team = t.name AND m.away_goals > m.home_goals) THEN 3
                    WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS Pts
        FROM teams t LEFT JOIN matches m ON m.home_team = t.name OR m.away_team = t.name
        GROUP BY t.name
        ORDER BY Pts DESC, GD DESC, GF DESC
        """
        df = pd.read_sql_query(query, conn)
        return df
    except Exception as e:
        print(f"Error in get_standings: {e}")
        # استعلام بديل في حالة وجود خطأ
        query_fallback = """
        SELECT t.name, t.country, t.group_char,
               COUNT(m.id) AS P,
               SUM(CASE WHEN (m.home_team = t.name AND m.home_goals > m.away_goals) OR 
                             (m.away_team = t.name AND m.away_goals > m.home_goals) THEN 1 ELSE 0 END) AS W,
               SUM(CASE WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS D,
               SUM(CASE WHEN (m.home_team = t.name AND m.home_goals < m.away_goals) OR 
                             (m.away_team = t.name AND m.away_goals < m.home_goals) THEN 1 ELSE 0 END) AS L,
               COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.home_goals ELSE m.away_goals END), 0) AS GF,
               COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.away_goals ELSE m.home_goals END), 0) AS GA,
               (COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.home_goals ELSE m.away_goals END), 0) -
                COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.away_goals ELSE m.home_goals END), 0)) AS GD,
               SUM(CASE WHEN (m.home_team = t.name AND m.home_goals > m.away_goals) OR 
                            (m.away_team = t.name AND m.away_goals > m.home_goals) THEN 3
                    WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS Pts
        FROM teams t LEFT JOIN matches m ON m.home_team = t.name OR m.away_team = t.name
        GROUP BY t.name
        ORDER BY Pts DESC, GD DESC, GF DESC
        """
        df = pd.read_sql_query(query_fallback, conn)
        df['eliminated'] = 0  # إضافة عمود افتراضي
        return df
    finally:
        conn.close()

def get_matches(stage=None):
    conn = sqlite3.connect(DB_PATH)
    try:
        if stage:
            df = pd.read_sql_query("SELECT * FROM matches WHERE stage = ? ORDER BY date, home_team", conn, params=(stage,))
        else:
            df = pd.read_sql_query("SELECT * FROM matches ORDER BY date, home_team", conn)
        return df
    except Exception as e:
        print(f"Error in get_matches: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

def eliminate_teams(team_names):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # إعادة تعيين جميع الفرق أولاً
        c.execute("UPDATE teams SET eliminated = 0")
        # ثم إقصاء الفرق المحددة
        for team in team_names:
            c.execute("UPDATE teams SET eliminated = 1 WHERE name = ?", (team,))
        conn.commit()
    except Exception as e:
        print(f"Error in eliminate_teams: {e}")
    finally:
        conn.close()

def reset_tournament():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("DELETE FROM matches")
        c.execute("UPDATE teams SET eliminated = 0")
        conn.commit()
    except Exception as e:
        print(f"Error in reset_tournament: {e}")
    finally:
        conn.close()

def get_knockout_pairs(stage):
    conn = sqlite3.connect(DB_PATH)
    try:
        df = pd.read_sql_query("""
            SELECT DISTINCT knockout_pair_id, home_team, away_team 
            FROM matches 
            WHERE stage = ? AND knockout_pair_id > 0 
            ORDER BY knockout_pair_id
        """, conn, params=(stage,))
        return df
    except Exception as e:
        print(f"Error in get_knockout_pairs: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

