def add_team(name_ar, name_en, country_ar, country_en, group):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("INSERT INTO teams (name_ar, name_en, country_ar, country_en, group_char) VALUES (?, ?, ?, ?, ?)", 
                  (name_ar, name_en, country_ar, country_en, group))
        conn.commit()
        return True
    except sqlite3.IntegrityError:
        return False
    finally:
        conn.close()

def add_match(home, away, hg, ag, date, stage, leg='single', pair_id=0):
    """إضافة مباراة جديدة إلى قاعدة البيانات"""
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # التأكد من صحة البيانات
        home = str(home) if home else ""
        away = str(away) if away else ""
        hg = int(hg) if hg is not None else 0
        ag = int(ag) if ag is not None else 0
        date = str(date) if date else QDate.currentDate().toString("yyyy-MM-dd")
        stage = str(stage) if stage else "Group Stage"
        leg = str(leg) if leg else "single"
        pair_id = int(pair_id) if pair_id else 0
        
        c.execute("""INSERT INTO matches (home_team, away_team, home_goals, away_goals, date, stage, leg, knockout_pair_id)
                     VALUES (?, ?, ?, ?, ?, ?, ?, ?)""",
                  (home, away, hg, ag, date, stage, leg, pair_id))
        conn.commit()
        return True
    except Exception as e:
        print(f"خطأ في إضافة المباراة: {e}")
        conn.rollback()
        return False
    finally:
        conn.close()

def get_teams(include_eliminated=False, include_banned=False):
    conn = sqlite3.connect(DB_PATH)
    try:
        query = "SELECT name_ar, name_en FROM teams WHERE 1=1"
        params = []
        
        if not include_eliminated:
            query += " AND eliminated = 0"
        if not include_banned:
            query += " AND banned = 0"
            
        query += " ORDER BY name_ar"
        
        df = pd.read_sql_query(query, conn, params=params)
        return df
    except Exception as e:
        print(f"Error in get_teams: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

def get_team_names(lang="ar", include_eliminated=False, include_banned=False):
    df = get_teams(include_eliminated, include_banned)
    if df.empty:
        return []
    
    if lang == "ar":
        return df["name_ar"].tolist()
    else:
        return df["name_en"].tolist()

