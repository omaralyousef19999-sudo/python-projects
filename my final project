    def _add_knockout_and_close(self, dlg, home, away, hg, ag, stage, leg='single'):
        if home and away and home != away:
            add_match(home, away, hg, ag, QDate.currentDate().toString("yyyy-MM-dd"), stage, leg)
            dlg.accept()
            self.populate_knockout_table()
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", "تمت الإضافة" if self.lang=="ar" else "Added")
        else:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "اختر فريقين مختلفين" if self.lang=="ar" else "Choose two different teams")

    def generate_demo_knockout_matches(self):
        try:
            teams = get_teams()
            if len(teams) < 2:
                QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "لا يوجد فرق كافية" if self.lang=="ar" else "Not enough teams")
                return
            
            stage = self.k_stage_combo.currentText()
            import random
            
            # نسخ القائمة وتحديد عدد المباريات الآمن
            available_teams = teams.copy()
            random.shuffle(available_teams)
            
            # تحديد العدد الآمن من المباريات (لا يزيد عن 4 مباريات = 8 فرق)
            max_matches = min(4, len(available_teams) // 2)
            match_count = 0
            
            for i in range(max_matches):
                pair_id = random.randint(1000, 9999)
                home = available_teams[i * 2]
                away = available_teams[i * 2 + 1]
                
                # مباراة الذهاب
                add_match(home, away, random.randint(0,4), random.randint(0,4), 
                         QDate.currentDate().toString("yyyy-MM-dd"), stage, 'first', pair_id)
                # مباراة الإياب
                add_match(away, home, random.randint(0,4), random.randint(0,4), 
                         QDate.currentDate().addDays(14).toString("yyyy-MM-dd"), stage, 'second', pair_id)
                match_count += 2
            
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                f"تم توليد {match_count} مباراة تجريبية" if self.lang=="ar" else f"Generated {match_count} demo matches")
            self.populate_knockout_table()
            
        except Exception as e:
            print(f"Error in generate_demo_knockout_matches: {e}")
            QMessageBox.critical(self, "خطأ" if self.lang=="ar" else "Error", 
                f"حدث خطأ غير متوقع: {str(e)}" if self.lang=="ar" else f"Unexpected error: {str(e)}")

