        reply = QMessageBox.question(self, 
            "تأكيد" if self.lang=="ar" else "Confirm",
            "هل تريد إعادة تعيين جميع مباريات الإقصائيات؟" if self.lang=="ar" else "Reset all knockout matches?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply == QMessageBox.StandardButton.Yes:
            conn = sqlite3.connect(DB_PATH)
            c = conn.cursor()
            c.execute("DELETE FROM matches WHERE stage != 'Group Stage'")
            c.execute("UPDATE teams SET eliminated = 0")
            conn.commit()
            conn.close()
            self.populate_knockout_table()
            self.update_qualified_teams()
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
