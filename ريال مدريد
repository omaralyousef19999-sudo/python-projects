        away_pen = QSpinBox(); away_pen.setRange(0, 10)
        
        match_date = QDateEdit()
        match_date.setDate(QDate.currentDate())
        match_date.setCalendarPopup(True)
        
        win_method_cb = QComboBox()
        if self.lang == "ar":
            win_method_cb.addItems(["الوقت الأصلي", "وقت إضافي", "ركلات ترجيح"])
        else:
            win_method_cb.addItems(["Normal Time", "Extra Time", "Penalties"])
        
        form.addRow("الفريق المضيف:" if self.lang=="ar" else "Home Team:", home_cb)
        form.addRow("الفريق الضيف:" if self.lang=="ar" else "Away Team:", away_cb)
        form.addRow("أهداف المضيف (الوقت الأصلي):" if self.lang=="ar" else "Home Goals (Normal Time):", hg)
        form.addRow("أهداف الضيف (الوقت الأصلي):" if self.lang=="ar" else "Away Goals (Normal Time):", ag)
        form.addRow("أهداف المضيف (وقت إضافي):" if self.lang=="ar" else "Home Goals (Extra Time):", home_extra)
        form.addRow("أهداف الضيف (وقت إضافي):" if self.lang=="ar" else "Away Goals (Extra Time):", away_extra)
        form.addRow("ركلات المضيف:" if self.lang=="ar" else "Home Penalties:", home_pen)
        form.addRow("ركلات الضيف:" if self.lang=="ar" else "Away Penalties:", away_pen)
        form.addRow("طريقة الفوز:" if self.lang=="ar" else "Win Method:", win_method_cb)
        form.addRow("التاريخ:" if self.lang=="ar" else "Date:", match_date)
        
        btns = QHBoxLayout()
        ok = QPushButton("إضافة" if self.lang=="ar" else "Add")
        
        def add_and_close():
            home_total = hg.value() + home_extra.value()
            away_total = ag.value() + away_extra.value()
            
            win_method_en = ""
            winner = ""
            
            if self.lang == "ar":
                if win_method_cb.currentText() == "الوقت الأصلي":
                    win_method_en = "normal"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                elif win_method_cb.currentText() == "وقت إضافي":
                    win_method_en = "extra_time"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                else:
                    win_method_en = "penalties"
                    winner = home_cb.currentText() if home_pen.value() > away_pen.value() else away_cb.currentText()
            else:
                if win_method_cb.currentText() == "Normal Time":
                    win_method_en = "normal"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                elif win_method_cb.currentText() == "Extra Time":
                    win_method_en = "extra_time"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                else:
                    win_method_en = "penalties"
                    winner = home_cb.currentText() if home_pen.value() > away_pen.value() else away_cb.currentText()
            
            date_str = match_date.date().toString("yyyy-MM-dd")
            self._add_knockout_and_close(dlg, home_cb.currentText(), away_cb.currentText(), 
