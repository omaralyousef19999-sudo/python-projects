    def export_docx(self, save_dialog=True):
        if Document is None:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "مكتبة python-docx غير مثبتة" if self.lang=="ar" else "python-docx not installed")
            return False

        default_name = f"UCL_Export_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"
        fname = QFileDialog.getSaveFileName(self, "حفظ Word" if self.lang=="ar" else "Save Word", default_name, "Word Files (*.docx)")[0] if save_dialog else default_name
        if not fname:
            return False
        try:
            doc = Document()
            doc.add_heading('UEFA Champions League - Export', 0)
            doc.add_paragraph(f"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
            doc.add_paragraph(" ")

            # جدول الترتيب
            st_df = get_standings()
            if not st_df.empty:
                doc.add_heading('Standings / الترتيب', level=1)
                table = doc.add_table(rows=1, cols=10)
                hdr_cells = table.rows[0].cells
                hdrs = ["Team","P","W","D","L","GF","GA","GD","Pts","Status"]
                for i, h in enumerate(hdrs):
                    hdr_cells[i].text = h
                for _, r in st_df.iterrows():
                    row_cells = table.add_row().cells
                    team_name = r["name_ar"] if self.lang == "ar" else r["name_en"]
                    if r.get("banned", 0):
                        status = "محظور" if self.lang == "ar" else "Banned"
                    elif r.get("eliminated", 0):
                        status = "مقصي" if self.lang == "ar" else "Eliminated"
                    else:
                        status = "نشط" if self.lang == "ar" else "Active"
                    row_cells[0].text = team_name
                    row_cells[1].text = str(int(r["P"]))
                    row_cells[2].text = str(int(r["W"]))
                    row_cells[3].text = str(int(r["D"]))
                    row_cells[4].text = str(int(r["L"]))
                    row_cells[5].text = str(int(r["GF"]))
                    row_cells[6].text = str(int(r["GA"]))
                    row_cells[7].text = str(int(r["GD"]))
                    row_cells[8].text = str(int(r["Pts"]))
                    row_cells[9].text = status
                doc.add_paragraph(" ")

            # نتائج الإقصائيات
            knockout_df = get_knockout_results()
            if not knockout_df.empty:
                doc.add_heading('Knockout Stages Results / نتائج الأدوار الإقصائية', level=1)
                
                stages = knockout_df["stage"].unique()
                for stage in stages:
                    doc.add_heading(stage, level=2)
                    stage_matches = knockout_df[knockout_df["stage"] == stage]
                    
                    table2 = doc.add_table(rows=1, cols=7)
                    hdr = table2.rows[0].cells
                    headers = ["Home", "Away", "Score", "ET", "Pens", "Winner", "Method"]
                    for i, h in enumerate(headers):
                        hdr[i].text = h
                    
                    for _, match in stage_matches.iterrows():
                        row = table2.add_row().cells
                        home = match["home_team"]
                        away = match["away_team"]
                        score = f"{match['home_goals']}-{match['away_goals']}"
                        
                        et = f"{match['home_extra_time_goals']}-{match['away_extra_time_goals']}" if match['home_extra_time_goals'] > 0 or match['away_extra_time_goals'] > 0 else "-"
                        pens = f"{match['home_penalties']}-{match['away_penalties']}" if match['home_penalties'] > 0 or match['away_penalties'] > 0 else "-"
                        
                        winner = match["winner"]
                        method = match["win_method"]
                        
                        if method == "normal":
                            method_text = "Normal Time"
                        elif method == "extra_time":
                            method_text = "Extra Time"
                        else:
                            method_text = "Penalties"
                        
                        row[0].text = home
                        row[1].text = away
                        row[2].text = score
                        row[3].text = et
                        row[4].text = pens
                        row[5].text = winner
                        row[6].text = method_text
                    
                    doc.add_paragraph(" ")

            doc.save(fname)
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", f"تم حفظ Word: {fname}" if self.lang=="ar" else f"Word saved: {fname}")
            return True
        except Exception as e:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", f"Failed to export Word: {e}")
            return False

