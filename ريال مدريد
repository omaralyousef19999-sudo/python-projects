    def generate_current_stage_matches(self):
        """توليد مباريات المرحلة الحالية تلقائياً"""
        try:
            current_stage = self.k_stage_combo.currentText()
            qualified_teams = get_qualified_for_next_stage(current_stage)
            
            if not qualified_teams:
                QMessageBox.warning(self, "تحذير" if self.lang=="ar" else "Warning",
                    "لا توجد فرق متأهلة للمرحلة الحالية" if self.lang=="ar" 
                    else "No qualified teams for current stage")
                return
            
            # تحديد عدد المباريات المطلوبة
            if current_stage == "Round of 16":
                required_teams = 16
                matches_needed = 8
            elif current_stage == "Quarter Final":
                required_teams = 8
                matches_needed = 4
            elif current_stage == "Semi Final":
                required_teams = 4
                matches_needed = 2
            elif current_stage == "Final":
                required_teams = 2
                matches_needed = 1
            else:
                return
            
            if len(qualified_teams) < required_teams:
                QMessageBox.warning(self, "تحذير" if self.lang=="ar" else "Warning",
                    f"يحتاج إلى {required_teams} فرق، يوجد فقط {len(qualified_teams)}" if self.lang=="ar" 
                    else f"Need {required_teams} teams, only {len(qualified_teams)} available")
                return
            
            # استخدام الفرق المتاحة
            available_teams = qualified_teams[:required_teams]
            random.shuffle(available_teams)
            match_count = 0
            base_date = QDate.currentDate()
            
            for i in range(matches_needed):
                home_team = available_teams[i * 2]
                away_team = available_teams[i * 2 + 1]
                
                match_date = base_date.addDays(i * 3).toString("yyyy-MM-dd")
                
                # توليد نتائج واقعية
                home_goals = random.randint(0, 3)
                away_goals = random.randint(0, 2)
                
                # تحديد الفائز وطريقة الفوز
                winner = ""
                win_method = "normal"
                home_extra = 0
                away_extra = 0
                home_pen = 0
                away_pen = 0
                
                if home_goals == away_goals:
                    # وقت إضافي
                    home_extra = random.randint(0, 2)
                    away_extra = random.randint(0, 2)
                    
                    if home_goals + home_extra == away_goals + away_extra:
                        # ركلات ترجيح
                        win_method = "penalties"
                        home_pen = random.randint(3, 5)
                        away_pen = random.randint(2, 4)
                        winner = home_team if home_pen > away_pen else away_team
                    else:
                        win_method = "extra_time"
                        winner = home_team if (home_goals + home_extra) > (away_goals + away_extra) else away_team
                else:
                    winner = home_team if home_goals > away_goals else away_team
                
                if add_match(home_team, away_team, home_goals, away_goals, match_date, 
                           current_stage, 'single', 0, home_extra, away_extra, 
                           home_pen, away_pen, winner, win_method):
                    match_count += 1
            
            if match_count > 0:
                QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                    f"تم توليد {match_count} مباراة لمرحلة {current_stage}" if self.lang=="ar" 
                    else f"Generated {match_count} matches for {current_stage} stage")
                
                self.populate_knockout_table()
                self.update_qualified_teams_display()
            else:
                QMessageBox.warning(self, "تحذير" if self.lang=="ar" else "Warning",
                    "لم يتم إضافة أي مباريات" if self.lang=="ar" else "No matches were added")
                
        except Exception as e:
            print(f"خطأ في توليد المباريات: {str(e)}")
            QMessageBox.critical(self, "خطأ" if self.lang=="ar" else "Error", 
                f"حدث خطأ أثناء توليد المباريات: {str(e)}" if self.lang=="ar" 
                else f"Error generating matches: {str(e)}")

    def advance_stage(self):
        """التقدم للمرحلة التالية تلقائياً"""
        current_stage = self.k_stage_combo.currentText()
        next_stage = ""
        
        if current_stage == "Round of 16":
            next_stage = "Quarter Final"
        elif current_stage == "Quarter Final":
            next_stage = "Semi Final"
        elif current_stage == "Semi Final":
            next_stage = "Final"
        else:
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                "البطولة انتهت!" if self.lang=="ar" else "Tournament finished!")
            return
        
        # الحصول على الفائزين من المرحلة الحالية
        winners = get_winners_from_stage(current_stage)
        
        if not winners:
            QMessageBox.warning(self, "تحذير" if self.lang=="ar" else "Warning",
                "لا توجد مباريات مكتملة في المرحلة الحالية" if self.lang=="ar" 
                else "No completed matches in current stage")
            return
        
        # إقصاء جميع الفرق غير الفائزة
        all_teams = get_all_teams()["name_ar"].tolist()
        eliminated_teams = [team for team in all_teams if team not in winners]
        eliminate_teams(eliminated_teams)
        
        QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
            f"تم التقدم ل{next_stage}. الفرق المتأهلة: {', '.join(winners)}" if self.lang=="ar" 
            else f"Advanced to {next_stage}. Qualified teams: {', '.join(winners)}")
        
        self.k_stage_combo.setCurrentText(next_stage)
        self.update_qualified_teams_display()
        self.populate_knockout_table()

