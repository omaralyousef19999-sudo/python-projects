def check_stage_completion(stage):
    """التحقق من اكتمال مرحلة معينة بشكل أكثر دقة"""
    try:
        matches = get_matches(stage)
        if matches.empty:
            print(f"لا توجد مباريات في مرحلة {stage}")
            return False
        
        # التحقق من أن جميع المباريات لها فائز
        completed_matches = matches[matches['winner'].notna() & (matches['winner'] != '')]
        completion_ratio = len(completed_matches) / len(matches)
        
        print(f"مرحلة {stage}: {len(completed_matches)}/{len(matches)} مباراة مكتملة ({completion_ratio:.1%})")
        
        return len(completed_matches) == len(matches)
        
    except Exception as e:
        print(f"خطأ في check_stage_completion: {e}")
        return False

