    def add_team_act(self):
        name_ar = self.t_name_ar.text().strip()
        name_en = self.t_name_en.text().strip()
        country_ar = self.t_country_ar.text().strip()
        country_en = self.t_country_en.text().strip()
        group = self.t_group.currentText()
        
        if name_ar and name_en and country_ar and country_en:
            if add_team(name_ar, name_en, country_ar, country_en, group):
                QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", "تم إضافة الفريق بنجاح" if self.lang=="ar" else "Team added")
