def add_match(home, away, hg, ag, date, stage, leg='single', pair_id=0, 
              home_extra=0, away_extra=0, home_pen=0, away_pen=0, winner=None, win_method='normal'):
    """إضافة مباراة جديدة إلى قاعدة البيانات"""
    conn = get_db_connection()
    if conn is None:
        return False
    c = conn.cursor()
    try:
        home = str(home) if home else ""
        away = str(away) if away else ""
        hg = int(hg) if hg is not None else 0
        ag = int(ag) if ag is not None else 0
        home_extra = int(home_extra) if home_extra is not None else 0
        away_extra = int(away_extra) if away_extra is not None else 0
        home_pen = int(home_pen) if home_pen is not None else 0
        away_pen = int(away_pen) if away_pen is not None else 0
        date = str(date) if date else QDate.currentDate().toString("yyyy-MM-dd")
        stage = str(stage) if stage else "Group Stage"
        leg = str(leg) if leg else "single"
        pair_id = int(pair_id) if pair_id else 0
        winner = str(winner) if winner else None
        win_method = str(win_method) if win_method else 'normal'
        
        c.execute("""INSERT INTO matches 
                    (home_team, away_team, home_goals, away_goals, home_extra_time_goals, away_extra_time_goals, 
                     home_penalties, away_penalties, date, stage, leg, knockout_pair_id, winner, win_method)
                     VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)""",
                  (home, away, hg, ag, home_extra, away_extra, home_pen, away_pen, 
                   date, stage, leg, pair_id, winner, win_method))
        
        match_id = c.lastrowid
        
        if stage != "Group Stage":
            c.execute("""INSERT INTO knockout_results 
                        (stage, match_id, home_team, away_team, home_goals, away_goals, 
                         home_extra_time_goals, away_extra_time_goals, home_penalties, away_penalties, 
                         winner, win_method, match_date)
                         VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)""",
                      (stage, match_id, home, away, hg, ag, home_extra, away_extra, 
                       home_pen, away_pen, winner, win_method, date))
        
        conn.commit()
        return True
    except Exception as e:
        print(f"خطأ في إضافة المباراة: {e}")
        conn.rollback()
        return False
    finally:
        conn.close()

