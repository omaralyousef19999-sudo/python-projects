                QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "الفريق موجود مسبقًا" if self.lang=="ar" else "Team already exists")
        else:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "املأ كل الحقول" if self.lang=="ar" else "Fill all fields")

