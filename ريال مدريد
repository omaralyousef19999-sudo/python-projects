        c = conn.cursor()
        
        # إيقاف مؤقتات SQLite
        c.execute("PRAGMA foreign_keys=OFF")
        
        # محاولة حذف جميع مباريات الإقصائيات
        print("🗑️ جاري حذف مباريات الإقصائيات...")
