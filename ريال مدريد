                        ('BACKGROUND', (0, 0), (-1, 0), rlcolors.HexColor("#32CD32")),
                        ('TEXTCOLOR', (0, 0), (-1, 0), rlcolors.white),
                        ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
                        ('GRID', (0, 0), (-1, -1), 0.5, rlcolors.gray),
                        ('FONTSIZE', (0, 0), (-1, -1), 8),
                    ]))
                    story.append(stage_tbl)
                    story.append(Spacer(1, 10))
            else:
                story.append(Paragraph("No matches available", styles['Normal']))
            
            story.append(Spacer(1, 20))

            # 3. نتائج الإقصائيات
            story.append(Paragraph("Knockout Stages Results", styles['Heading2']))
            story.append(Spacer(1, 10))
            
            knockout_df = get_knockout_results()
            if not knockout_df.empty:
                knockout_table_data = []
                
                knockout_headers = ["Stage", "Home", "Away", "Score", "Extra Time", "Penalties", "Winner"]
                knockout_table_data.append(knockout_headers)
                
                for _, match in knockout_df.iterrows():
                    stage = match['stage']
                    home = match['home_team']
                    away = match['away_team']
                    
                    # البحث عن الأسماء الإنجليزية
                    all_teams = get_all_teams()
                    home_en = home
                    away_en = away
                    winner_en = match.get('winner', '')
                    
                    for _, team in all_teams.iterrows():
                        if team["name_ar"] == home:
                            home_en = team["name_en"]
                        if team["name_ar"] == away:
                            away_en = team["name_en"]
                        if team["name_ar"] == winner_en:
                            winner_en = team["name_en"]
                    
                    score = f"{match['home_goals']}-{match['away_goals']}"
                    
                    et = f"{match.get('home_extra_time_goals', 0)}-{match.get('away_extra_time_goals', 0)}"
                    if et == "0-0":
                        et = "-"
                    
                    pens = f"{match.get('home_penalties', 0)}-{match.get('away_penalties', 0)}"
                    if pens == "0-0":
                        pens = "-"
                    
                    knockout_table_data.append([stage, home_en, away_en, score, et, pens, winner_en])
                
                knockout_tbl = RLTable(knockout_table_data, repeatRows=1)
                knockout_tbl.setStyle(TableStyle([
                    ('BACKGROUND', (0, 0), (-1, 0), rlcolors.HexColor("#FF6B6B")),
                    ('TEXTCOLOR', (0, 0), (-1, 0), rlcolors.white),
                    ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
                    ('GRID', (0, 0), (-1, -1), 0.5, rlcolors.gray),
                    ('FONTSIZE', (0, 0), (-1, -1), 8),
                ]))
                story.append(knockout_tbl)
            else:
                story.append(Paragraph("No knockout results available", styles['Normal']))

            # بناء المستند
            doc.build(story)
            
            if save_dialog:
                QMessageBox.information(self, "تم", 
                    f"تم تصدير التقرير بنجاح: {fname}")
            
            return True
            
        except Exception as e:
            QMessageBox.warning(self, "خطأ", 
                f"خطأ في التصدير: {str(e)}")
            return False

    def export_docx(self, save_dialog=True):
        """تصدير التقرير إلى مستند Word"""
        if not DOCX_AVAILABLE:
            QMessageBox.warning(self, "خطأ", 
                               "مكتبة python-docx غير مثبتة")
            return False

        try:
            if save_dialog:
                default_name = f"UCL_Report_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"
                fname = QFileDialog.getSaveFileName(self, 
                    "حفظ التقرير Word", 
                    default_name, "Word Documents (*.docx)")[0]
                if not fname:
                    return False
            else:
                fname = f"UCL_Report_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"

            doc = Document()
            
            # العنوان الرئيسي
            title = doc.add_heading("UEFA Champions League Report - Season 2025", 0)
            title.alignment = 1  # مركز
            
            # تاريخ التصدير
            date_para = doc.add_paragraph()
            date_para.alignment = 1
            date_run = date_para.add_run(f"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
            date_run.italic = True
            
            doc.add_paragraph()  # سطر فارغ

            # 1. جدول الترتيب
            doc.add_heading("Standings Table", level=1)
            
            standings_df = get_standings()
            if not standings_df.empty:
                table = doc.add_table(rows=len(standings_df) + 1, cols=7)
                table.style = 'Table Grid'
                
                # عناوين الأعمدة بالإنجليزية
                headers = ["Pos", "Team", "Group", "P", "W", "D", "L", "GF", "GA", "GD", "Pts"]
                
                for i, header in enumerate(headers[:7]):  # أول 7 أعمدة فقط لتجنب الاتساع
                    table.cell(0, i).text = header
                
                # بيانات الترتيب
                for i, row in standings_df.iterrows():
                    # استخدام الأسماء الإنجليزية
                    team_name = row["name_en"]
                    table.cell(i + 1, 0).text = str(i + 1)
                    table.cell(i + 1, 1).text = team_name
                    table.cell(i + 1, 2).text = row["group_char"]
                    table.cell(i + 1, 3).text = str(row["P"])
                    table.cell(i + 1, 4).text = str(row["W"])
                    table.cell(i + 1, 5).text = str(row["D"])
                    table.cell(i + 1, 6).text = str(row["L"])
            
            doc.add_paragraph()  # سطر فارغ

            # 2. المباريات حسب المرحلة
            doc.add_heading("Matches", level=1)
            
            matches_df = get_matches()
            if not matches_df.empty:
                stages = matches_df['stage'].unique()
                
                for stage in stages:
                    doc.add_heading(stage, level=2)
                    stage_matches = matches_df[matches_df['stage'] == stage]
                    
                    stage_table = doc.add_table(rows=len(stage_matches) + 1, cols=4)
                    stage_table.style = 'Table Grid'
                    
                    stage_headers = ["Home", "Score", "Away", "Date"]
                    
                    for i, header in enumerate(stage_headers):
                        stage_table.cell(0, i).text = header
                    
                    for i, match in stage_matches.iterrows():
                        # استخدام الأسماء الإنجليزية
                        home_team = match['home_team']
                        away_team = match['away_team']
                        
                        # البحث عن الأسماء الإنجليزية
                        all_teams = get_all_teams()
                        home_en = home_team
                        away_en = away_team
                        
                        for _, team in all_teams.iterrows():
                            if team["name_ar"] == home_team:
                                home_en = team["name_en"]
                            if team["name_ar"] == away_team:
                                away_en = team["name_en"]
                        
                        stage_table.cell(i + 1, 0).text = home_en
                        stage_table.cell(i + 1, 1).text = f"{match['home_goals']} - {match['away_goals']}"
                        stage_table.cell(i + 1, 2).text = away_en
                        stage_table.cell(i + 1, 3).text = match['date']
            
            doc.add_paragraph()  # سطر فارغ

            # 3. البطل النهائي (إذا كان موجوداً)
            final_matches = get_matches("Final")
            if not final_matches.empty and final_matches.iloc[0].get('winner'):
                champion = final_matches.iloc[0]['winner']
                # البحث عن الاسم الإنجليزي للبطل
                all_teams = get_all_teams()
                champion_en = champion
                for _, team in all_teams.iterrows():
                    if team["name_ar"] == champion:
                        champion_en = team["name_en"]
                
                doc.add_heading("Champion", level=1)
                champion_para = doc.add_paragraph()
                champion_run = champion_para.add_run(champion_en)
                champion_run.bold = True
                champion_run.font.size = docx.shared.Pt(16)

            # حفظ المستند
            doc.save(fname)
            
            if save_dialog:
                QMessageBox.information(self, "تم", 
                    f"تم تصدير التقرير بنجاح: {fname}")
            
            return True
            
        except Exception as e:
            QMessageBox.warning(self, "خطأ", 
                f"خطأ في التصدير: {str(e)}")
            return False

