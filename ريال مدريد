    def populate_teams_table(self):
        df = get_all_teams()
        self.teams_table.setColumnCount(8)
        headers = ["الاسم العربي", "الاسم الإنجليزي", "الدولة عربي", "الدولة إنجليزي", "المجموعة", "الحالة", "محظور", "إجراءات"] if self.lang=="ar" else ["Arabic Name", "English Name", "Country (Ar)", "Country (En)", "Group", "Status", "Banned", "Actions"]
        self.teams_table.setHorizontalHeaderLabels(headers)
        self.teams_table.setRowCount(len(df))
        
        for i, row in df.iterrows():
            self.teams_table.setItem(i, 0, QTableWidgetItem(str(row["name_ar"])))
            self.teams_table.setItem(i, 1, QTableWidgetItem(str(row["name_en"])))
            self.teams_table.setItem(i, 2, QTableWidgetItem(str(row["country_ar"])))
            self.teams_table.setItem(i, 3, QTableWidgetItem(str(row["country_en"])))
            self.teams_table.setItem(i, 4, QTableWidgetItem(str(row["group_char"])))
            
            status = "مستبعد" if row.get("eliminated", 0) else "نشط"
            status_item = QTableWidgetItem(status)
            if row.get("eliminated", 0):
                status_item.setBackground(QColor(255, 100, 100, 150))  # أحمر للفرق المستبعدة
            else:
                status_item.setBackground(QColor(100, 255, 100, 150))  # أخضر للفرق النشطة
            self.teams_table.setItem(i, 5, status_item)
            
            banned_status = "نعم" if row.get("banned", 0) else "لا"
            banned_item = QTableWidgetItem(banned_status)
            if row.get("banned", 0):
                banned_item.setBackground(QColor(255, 0, 0, 150))
            self.teams_table.setItem(i, 6, banned_item)
            
            actions_widget = QWidget()
            actions_layout = QHBoxLayout(actions_widget)
            actions_layout.setContentsMargins(4, 4, 4, 4)
            
            delete_btn = QPushButton("حذف")
            delete_btn.setStyleSheet("background: #FF6B6B; color: white; padding: 5px; font-size: 12px;")
            delete_btn.clicked.connect(lambda checked, team=row["name_ar"]: self.delete_team_confirm(team))
            
            ban_btn = QPushButton("حظر")
            if row.get("banned", 0):
                ban_btn.setText("فك الحظر")
                ban_btn.setStyleSheet("background: #FFA500; color: white; padding: 5px; font-size: 12px;")
            else:
                ban_btn.setStyleSheet("background: #FF6B6B; color: white; padding: 5px; font-size: 12px;")
            ban_btn.clicked.connect(lambda checked, team=row["name_ar"], current=row.get("banned", 0): self.toggle_ban_team(team, current))
            
            actions_layout.addWidget(delete_btn)
            actions_layout.addWidget(ban_btn)
            self.teams_table.setCellWidget(i, 7, actions_widget)
        
        self.teams_table.resizeColumnsToContents()

    def delete_team_confirm(self, team_name):
        reply = QMessageBox.question(self, 
            "تأكيد الحذف",
            f"هل تريد حذف الفريق {team_name}؟ سيتم حذف جميع مبارياته أيضاً." if self.lang=="ar" else f"Delete team {team_name}? All its matches will also be deleted.",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply == QMessageBox.StandardButton.Yes:
            if delete_team(team_name):
                QMessageBox.information(self, "تم", 
                    "تم حذف الفريق بنجاح" if self.lang=="ar" else "Team deleted successfully")
                self.populate_teams_table()
            else:
                QMessageBox.warning(self, "خطأ", 
                    "فشل في حذف الفريق" if self.lang=="ar" else "Failed to delete team")

    def toggle_ban_team(self, team_name, current_status):
        new_status = 0 if current_status else 1
        action = "فك الحظر" if new_status == 0 else "حظر"
        
        reply = QMessageBox.question(self, 
            "تأكيد",
            f"هل تريد {action} الفريق {team_name}؟" if self.lang=="ar" else f"{action} team {team_name}?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply == QMessageBox.StandardButton.Yes:
            ban_team(team_name, new_status)
            QMessageBox.information(self, "تم", 
                f"تم {action} الفريق بنجاح" if self.lang=="ar" else f"Team {action.lower()}ed successfully")
            self.populate_teams_table()

    def add_team_act(self):
        name_ar = self.t_name_ar.text().strip()
        name_en = self.t_name_en.text().strip()
        country_ar = self.t_country_ar.text().strip()
        country_en = self.t_country_en.text().strip()
        group = self.t_group.currentText()
        
        if name_ar and name_en and country_ar and country_en:
            if add_team(name_ar, name_en, country_ar, country_en, group):
                QMessageBox.information(self, "تم", "تم إضافة الفريق بنجاح" if self.lang=="ar" else "Team added")
                self.t_name_ar.clear()
                self.t_name_en.clear()
                self.t_country_ar.clear()
                self.t_country_en.clear()
                self.populate_teams_table()
                self.refresh_ui()
            else:
                QMessageBox.warning(self, "خطأ", "الفريق موجود مسبقًا" if self.lang=="ar" else "Team already exists")
        else:
            QMessageBox.warning(self, "خطأ", "املأ كل الحقول" if self.lang=="ar" else "Fill all fields")

