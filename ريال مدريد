def get_knockout_matches():
    """الحصول على جميع مباريات الإقصائيات مع التفاصيل الكاملة"""
    conn = sqlite3.connect(DB_PATH)
    try:
        df = pd.read_sql_query("""
            SELECT * FROM matches 
            WHERE stage != 'Group Stage' 
            ORDER BY 
                CASE stage
                    WHEN 'Round of 16' THEN 1
                    WHEN 'Quarter Final' THEN 2
                    WHEN 'Semi Final' THEN 3
                    WHEN 'Final' THEN 4
                    ELSE 5
                END, date
        """, conn)
        return df
    except Exception as e:
        print(f"Error in get_knockout_matches: {e}")
        return pd.DataFrame()
    finally:
        conn.close()

