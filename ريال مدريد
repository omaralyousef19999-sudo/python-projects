# ---------- قاعدة البيانات وتهيئتها ----------
def get_db_connection():
    """الحصول على اتصال بقاعدة البيانات مع معالجة الأقفال"""
    conn = sqlite3.connect(DB_PATH, timeout=30)
    conn.execute("PRAGMA journal_mode=WAL")  # تحسين الأداء مع العمليات المتزامنة
    conn.execute("PRAGMA busy_timeout=30000")  # زيادة وقت الانتظار
    return conn

def init_db():
