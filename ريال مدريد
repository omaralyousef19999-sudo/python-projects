            winner = ""
            
            if self.lang == "ar":
                if win_method_cb.currentText() == "الوقت الأصلي":
                    win_method_en = "normal"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                elif win_method_cb.currentText() == "وقت إضافي":
                    win_method_en = "extra_time"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                else:
                    win_method_en = "penalties"
                    winner = home_cb.currentText() if home_pen.value() > away_pen.value() else away_cb.currentText()
            else:
                if win_method_cb.currentText() == "Normal Time":
                    win_method_en = "normal"
                    winner = home_cb.currentText() if home_total > away_total else away_cb.currentText()
                elif win_method_cb.currentText() == "Extra Time":
