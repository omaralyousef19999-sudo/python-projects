    def export_knockout_results(self):
        """تصدير نتائج الإقصائيات فقط"""
        if SimpleDocTemplate is None:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "مكتبة reportlab غير مثبتة" if self.lang=="ar" else "reportlab not installed")
            return False

        default_name = f"UCL_Knockout_Results_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf"
        fname = QFileDialog.getSaveFileName(self, "حفظ نتائج الإقصائيات" if self.lang=="ar" else "Save Knockout Results", default_name, "PDF Files (*.pdf)")[0]
        if not fname:
            return False

        try:
            doc = SimpleDocTemplate(fname, pagesize=A4)
            styles = getSampleStyleSheet()
            story = []
            
            title_style = ParagraphStyle('title', parent=styles['Heading1'], alignment=1, fontSize=18, textColor=rlcolors.HexColor("#003f7f"))
            story.append(Paragraph("UEFA Champions League - Knockout Stages Results", title_style))
            story.append(Spacer(1, 12))
            story.append(Paragraph(f"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}", styles['Normal']))
            story.append(Spacer(1, 12))

            stages = ["Round of 16", "Quarter Final", "Semi Final", "Final"]
            
            for stage in stages:
                story.append(Paragraph(stage, styles['Heading2']))
                story.append(Spacer(1, 6))
                
                matches = get_matches(stage)
                if not matches.empty:
                    table_data = [["Home", "Away", "Score", "ET", "Pens", "Winner", "Method"]]
                    
                    for _, match in matches.iterrows():
                        home = match["home_team"]
                        away = match["away_team"]
                        score = f"{match['home_goals']}-{match['away_goals']}"
                        
                        et = f"{match.get('home_extra_time_goals', 0)}-{match.get('away_extra_time_goals', 0)}" if match.get('home_extra_time_goals', 0) > 0 or match.get('away_extra_time_goals', 0) > 0 else "-"
                        pens = f"{match.get('home_penalties', 0)}-{match.get('away_penalties', 0)}" if match.get('home_penalties', 0) > 0 or match.get('away_penalties', 0) > 0 else "-"
                        
                        winner = match.get("winner", "")
                        method = match.get("win_method", "normal")
                        
                        if method == "normal":
                            method_text = "Normal Time"
                        elif method == "extra_time":
                            method_text = "Extra Time"
                        else:
                            method_text = "Penalties"
                        
                        table_data.append([home, away, score, et, pens, winner, method_text])
                    
                    tbl = RLTable(table_data, repeatRows=1)
                    tbl.setStyle(TableStyle([
                        ('BACKGROUND', (0,0), (-1,0), rlcolors.HexColor("#1E90FF")),
                        ('TEXTCOLOR', (0,0), (-1,0), rlcolors.white),
                        ('GRID', (0,0), (-1,-1), 0.25, rlcolors.gray),
                        ('ALIGN', (1,1), (-1,-1), 'CENTER'),
                    ]))
                    story.append(tbl)
                else:
                    story.append(Paragraph("No matches played", styles['Normal']))
                
                story.append(Spacer(1, 12))

            doc.build(story)
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                f"تم تصدير نتائج الإقصائيات: {fname}" if self.lang=="ar" 
                else f"Knockout results exported: {fname}")
            return True
            
        except Exception as e:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", 
                f"فشل في تصدير النتائج: {e}" if self.lang=="ar" 
                else f"Failed to export results: {e}")
            return False

