    def update_qualified_teams_display(self):
        """تحديث عرض الفرق المتأهلة تلقائياً من المباريات"""
        for i in reversed(range(self.qualified_grid.count())): 
            self.qualified_grid.itemAt(i).widget().setParent(None)
        
        stages = ["Round of 16", "Quarter Final", "Semi Final", "Final"]
        
        for i, stage in enumerate(stages):
            if stage == "Round of 16":
                qualified_teams = get_qualified_for_next_stage_correct("Group Stage")
            else:
                qualified_teams = get_qualified_for_next_stage_correct(stage)
            
            stage_label = QLabel(f"{stage}:" if self.lang == "en" else f"{self.get_stage_name_ar(stage)}:")
            stage_label.setStyleSheet("font-weight: bold; color: #FFD700; font-size: 14px;")
            self.qualified_grid.addWidget(stage_label, i, 0)
            
            if qualified_teams:
