    def start_full_auto_generation(self):
        """بدء التوليد التلقائي الكامل باستخدام Thread"""
        reply = QMessageBox.question(self, 
            "بدء التوليد التلقائي" if self.lang=="ar" else "Start Auto-Generation",
            "سيتم توليد جميع مراحل البطولة تلقائياً. هل تريد المتابعة؟" if self.lang=="ar" 
            else "All tournament stages will be generated automatically. Do you want to continue?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply != QMessageBox.StandardButton.Yes:
            return
        
        # إعداد واجهة المستخدم
        self.auto_gen_btn.setEnabled(False)
        self.cancel_btn.setVisible(True)
        self.progress_bar.setVisible(True)
        self.progress_bar.setValue(0)
        self.current_stage_label.setText("جاري البدء..." if self.lang=="ar" else "Starting...")
        
        # إنشاء وتشغيل Thread التوليد
        self.generation_thread = GenerationThread()
        self.generation_thread.progress_updated.connect(self.progress_bar.setValue)
        self.generation_thread.stage_updated.connect(self.current_stage_label.setText)
        self.generation_thread.finished_signal.connect(self.generation_finished)
        self.generation_thread.start()

    def cancel_auto_generation(self):
        """إلغاء عملية التوليد"""
        if self.generation_thread and self.generation_thread.isRunning():
            self.generation_thread.cancel()
            self.current_stage_label.setText("جاري الإلغاء..." if self.lang=="ar" else "Cancelling...")

    def generation_finished(self, success, message):
        """معالجة انتهاء التوليد"""
        self.auto_gen_btn.setEnabled(True)
        self.cancel_btn.setVisible(False)
        self.progress_bar.setVisible(False)
        
        if success:
            self.current_stage_label.setText("اكتمل التوليد بنجاح!" if self.lang=="ar" else "Generation completed successfully!")
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Success", message)
        else:
            self.current_stage_label.setText("فشل التوليد" if self.lang=="ar" else "Generation failed")
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", message)
        
        # تحديث الواجهة
        self.refresh_ui()

