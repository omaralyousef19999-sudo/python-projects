        teams_df = get_all_teams()
        if teams_df.empty:
            print("لا توجد فرق في قاعدة البيانات")
            return 0
        
        match_count = 0
        base_date = QDate.currentDate()
        
        # تجميع الفرق حسب المجموعات
        groups = {}
        for _, team in teams_df.iterrows():
            group = team["group_char"]
            if group not in groups:
                groups[group] = []
            groups[group].append(team["name_ar"])
        
        print(f"تم تجميع {len(groups)} مجموعة")
        
        # توليد مباريات كل مجموعة
        for group, group_teams in groups.items():
            if len(group_teams) < 4:
                print(f"المجموعة {group} تحتوي على أقل من 4 فرق")
                continue
            
            print(f"جاري توليد مباريات المجموعة {group}...")
            
            # توليد جميع المباريات الممكنة في المجموعة (ذهاب وإياب)
            match_days = 0
            
            for i in range(len(group_teams)):
                for j in range(i + 1, len(group_teams)):
                    # مباراة الذهاب
                    home_team = group_teams[i]
                    away_team = group_teams[j]
                    match_date = base_date.addDays(match_days).toString("yyyy-MM-dd")
                    
                    # نتائج عشوائية منطقية
                    home_goals = random.randint(0, 4)
                    away_goals = random.randint(0, 3)
                    
                    if add_match(home_team, away_team, home_goals, away_goals, match_date, "Group Stage"):
                        match_count += 1
                        print(f"تمت إضافة مباراة: {home_team} vs {away_team} - {home_goals}-{away_goals}")
                    
                    # مباراة الإياب (بعد 3 أيام)
                    match_date_return = base_date.addDays(match_days + 3).toString("yyyy-MM-dd")
                    home_goals_return = random.randint(0, 3)
                    away_goals_return = random.randint(0, 4)
                    
                    if add_match(away_team, home_team, home_goals_return, away_goals_return, match_date_return, "Group Stage"):
                        match_count += 1
                        print(f"تمت إضافة مباراة: {away_team} vs {home_team} - {home_goals_return}-{away_goals_return}")
                    
                    # زيادة الأيام بعد كل زوج من المباريات
                    match_days += 6
        
        print(f"تم توليد {match_count} مباراة في دور المجموعات")
        return match_count
        
    except Exception as e:
        print(f"خطأ في توليد مباريات المجموعات: {e}")
        traceback.print_exc()
        conn.rollback()
        return 0
    finally:
        conn.close()

def generate_round_of_16_correct():
    """توليد مباريات دور الـ16 بشكل صحيح حسب القواعد الرسمية"""
    try:
        # الحصول على المتصدرين والمركز الثاني من كل مجموعة
        qualified_teams = get_qualified_teams_correct()
        
        if len(qualified_teams) < 16:
            print(f"عدد الفرق المتأهلة غير كافي: {len(qualified_teams)} من 16")
            return 0
        
        # فصل المتصدرين والمركز الثاني
        group_winners = [team for team in qualified_teams if qualified_teams.index(team) < 8]
        runners_up = [team for team in qualified_teams if qualified_teams.index(team) >= 8]
        
        print(f"المتصدرون: {[w['name'] for w in group_winners]}")
        print(f"المركز الثاني: {[r['name'] for r in runners_up]}")
        
        # توليد المباريات: متصدر ضد مركز ثاني من مجموعة مختلفة
        match_count = 0
        base_date = QDate.currentDate()
        
        # خلط القوائم لتوليد مباريات عشوائية
        random.shuffle(group_winners)
        random.shuffle(runners_up)
        
        used_runners = set()
        
        for i, winner in enumerate(group_winners):
            # إيجاد مركز ثاني من مجموعة مختلفة
            suitable_runner = None
            for runner in runners_up:
                if runner['name'] not in used_runners and runner['group'] != winner['group']:
                    suitable_runner = runner
                    break
            
            if suitable_runner is None:
                # إذا لم نجد مركز ثاني من مجموعة مختلفة، نأخذ أي مركز ثاني متبقي
                for runner in runners_up:
                    if runner['name'] not in used_runners:
                        suitable_runner = runner
                        break
            
            if suitable_runner:
                home_team = winner['name']
                away_team = suitable_runner['name']
                used_runners.add(suitable_runner['name'])
                
                match_date = base_date.addDays(i * 3).toString("yyyy-MM-dd")
                
                # نتائج واقعية
                home_goals = random.randint(0, 3)
                away_goals = random.randint(0, 2)
                
                # تحديد الفائز
                winner_team = ""
                win_method = "normal"
                home_extra = 0
                away_extra = 0
                home_pen = 0
                away_pen = 0
                
                if home_goals > away_goals:
                    winner_team = home_team
                elif away_goals > home_goals:
                    winner_team = away_team
                else:
                    # وقت إضافي
                    home_extra = random.randint(0, 1)
                    away_extra = random.randint(0, 1)
                    if home_goals + home_extra > away_goals + away_extra:
                        winner_team = home_team
                        win_method = "extra_time"
                    elif away_goals + away_extra > home_goals + home_extra:
                        winner_team = away_team
                        win_method = "extra_time"
                    else:
                        # ركلات ترجيح
                        home_pen = random.randint(3, 5)
                        away_pen = random.randint(2, 4)
                        winner_team = home_team if home_pen > away_pen else away_team
                        win_method = "penalties"
                
                if add_match(home_team, away_team, home_goals, away_goals, match_date, 
                           "Round of 16", 'single', 0, home_extra, away_extra, 
                           home_pen, away_pen, winner_team, win_method):
                    match_count += 1
                    print(f"مباراة دور الـ16: {home_team} ({winner['group']}) vs {away_team} ({suitable_runner['group']}) - الفائز: {winner_team}")
        
        print(f"تم توليد {match_count} مباراة في دور الـ16")
        return match_count
        
    except Exception as e:
        print(f"خطأ في توليد دور الـ16: {e}")
        traceback.print_exc()
        return 0

def generate_knockout_stage_matches(stage):
    """توليد مباريات مرحلة إقصائية تلقائياً - الإصدار المعدل"""
    try:
        # الحصول على الفرق المتأهلة لهذه المرحلة
        if stage == "Round of 16":
            qualified_teams = get_qualified_for_next_stage_correct("Group Stage")
        else:
            qualified_teams = get_qualified_for_next_stage_correct(stage)
        
        print(f"الفرق المتأهلة لمرحلة {stage}: {qualified_teams}")
        
        if not qualified_teams:
            print(f"لا توجد فرق متأهلة لمرحلة {stage}")
            return 0
        
        # تحديد عدد المباريات المطلوبة
        if stage == "Round of 16":
            required_teams = 16
            matches_needed = 8
        elif stage == "Quarter Final":
            required_teams = 8
            matches_needed = 4
        elif stage == "Semi Final":
            required_teams = 4
            matches_needed = 2
        elif stage == "Final":
            required_teams = 2
            matches_needed = 1
        else:
            return 0
        
        if len(qualified_teams) < required_teams:
            print(f"عدد الفرق المتأهلة ({len(qualified_teams)}) أقل من المطلوب ({required_teams})")
            return 0
        
        # استخدام الفرق المتاحة
        available_teams = qualified_teams[:required_teams]
        random.shuffle(available_teams)
        match_count = 0
        base_date = QDate.currentDate()
        
        print(f"جاري توليد {matches_needed} مباراة لمرحلة {stage}...")
        
        for i in range(matches_needed):
            home_team = available_teams[i * 2]
            away_team = available_teams[i * 2 + 1]
            
            match_date = base_date.addDays(i * 3).toString("yyyy-MM-dd")
            
            # توليد نتائج واقعية
            home_goals = random.randint(0, 3)
            away_goals = random.randint(0, 2)
            
            # تحديد الفائز وطريقة الفوز
            winner = ""
            win_method = "normal"
            home_extra = 0
            away_extra = 0
            home_pen = 0
            away_pen = 0
            
            if home_goals == away_goals:
                # وقت إضافي
                home_extra = random.randint(0, 2)
                away_extra = random.randint(0, 2)
                
                if home_goals + home_extra == away_goals + away_extra:
                    # ركلات ترجيح
                    win_method = "penalties"
                    home_pen = random.randint(3, 5)
                    away_pen = random.randint(2, 4)
                    winner = home_team if home_pen > away_pen else away_team
                else:
                    win_method = "extra_time"
                    winner = home_team if (home_goals + home_extra) > (away_goals + away_extra) else away_team
            else:
                winner = home_team if home_goals > away_goals else away_team
            
            if add_match(home_team, away_team, home_goals, away_goals, match_date, 
                       stage, 'single', 0, home_extra, away_extra, 
                       home_pen, away_pen, winner, win_method):
                match_count += 1
                print(f"تمت إضافة مباراة إقصائية: {home_team} vs {away_team} - الفائز: {winner}")
        
        print(f"تم توليد {match_count} مباراة في مرحلة {stage}")
        return match_count
        
    except Exception as e:
        print(f"خطأ في توليد مباريات مرحلة {stage}: {e}")
        traceback.print_exc()
        return 0

