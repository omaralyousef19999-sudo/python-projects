    def reset_matches(self):
        reply = QMessageBox.question(self, 
            "تأكيد الحذف",
            "هل تريد حذف جميع المباريات؟" if self.lang=="ar" else "Delete all matches?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply == QMessageBox.StandardButton.Yes:
            conn = get_db_connection()
            if conn is None:
                return
            c = conn.cursor()
            c.execute("DELETE FROM matches")
            c.execute("DELETE FROM knockout_results")
            conn.commit()
            conn.close()
            self.populate_matches_table()
            QMessageBox.information(self, "تم", 
                "تم حذف جميع المباريات" if self.lang=="ar" else "All matches deleted")

    def add_match_act(self):
        h = self.h.currentText()
        a = self.a.currentText()
        stage = self.stage_combo.currentText()
        date = self.match_date.date().toString("yyyy-MM-dd")
        
        try:
            hg = int(self.hg.text()) if self.hg.text() else 0
            ag = int(self.ag.text()) if self.ag.text() else 0
        except ValueError:
            QMessageBox.warning(self, "خطأ", 
                "أدخل أرقاماً صحيحة للأهداف" if self.lang=="ar" else "Enter valid numbers for goals")
            return
        
        if h and a and h != a:
            if add_match(h, a, hg, ag, date, stage):
                QMessageBox.information(self, "تم", "تمت الإضافة")
                self.populate_matches_table()
                self.hg.setText("0")
                self.ag.setText("0")
            else:
                QMessageBox.warning(self, "خطأ", "فشل في إضافة المباراة")
        else:
            QMessageBox.warning(self, "خطأ", "اختر فريقين مختلفين")

    def populate_matches_table(self):
        sel = self.show_stage_combo.currentText()
        if sel == "All":
            df = get_matches()
        else:
            df = get_matches(sel)
        
        self.matches_table.setColumnCount(9)
        headers = ["المضيف", "الضيف", "أهداف المضيف", "أهداف الضيف", "التاريخ", "الجولة", "النوع", "الحالة", "إجراءات"] if self.lang=="ar" else ["Home", "Away", "Home Goals", "Away Goals", "Date", "Stage", "Leg", "Status", "Actions"]
        self.matches_table.setHorizontalHeaderLabels(headers)
        self.matches_table.setRowCount(len(df))
        
        for i, row in df.iterrows():
            for j, key in enumerate(["home_team","away_team","home_goals","away_goals","date","stage"]):
                self.matches_table.setItem(i, j, QTableWidgetItem(str(row[key])))
            
            leg_type = "ذهاب" if row.get("leg") == "first" else "إياب" if row.get("leg") == "second" else "مفردة"
            if self.lang == "en":
                leg_type = "1st Leg" if row.get("leg") == "first" else "2nd Leg" if row.get("leg") == "second" else "Single"
            self.matches_table.setItem(i, 6, QTableWidgetItem(leg_type))
            
            status = row.get("status", "scheduled")
            status_text = "مجدولة" if status == "scheduled" else "مكتملة" if status == "completed" else "ملغاة"
            if self.lang == "en":
                status_text = "Scheduled" if status == "scheduled" else "Completed" if status == "completed" else "Cancelled"
            status_item = QTableWidgetItem(status_text)
            
            if status == "completed":
                status_item.setBackground(QColor(100, 255, 100, 150))
            elif status == "cancelled":
                status_item.setBackground(QColor(255, 100, 100, 150))
            
            self.matches_table.setItem(i, 7, status_item)
            
            delete_btn = QPushButton("حذف")
            delete_btn.setStyleSheet("background: #FF6B6B; color: white; padding: 5px; font-size: 12px;")
            delete_btn.clicked.connect(lambda checked, mid=row["id"]: self.delete_match_confirm(mid))
            
            cell_widget = QWidget()
            cell_layout = QHBoxLayout(cell_widget)
            cell_layout.addWidget(delete_btn)
            cell_layout.setContentsMargins(4, 4, 4, 4)
            self.matches_table.setCellWidget(i, 8, cell_widget)
        
        self.matches_table.resizeColumnsToContents()

