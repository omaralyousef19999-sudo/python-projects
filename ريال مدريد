def get_qualified_teams_correct():
    """الحصول على الفرق المتأهلة حسب قواعد دوري الأبطال الحقيقية - المتصدرين والمركز الثاني"""
    try:
        df = get_group_standings()
        
        if df.empty:
            print("❌ لا توجد بيانات للترتيب")
            return []
        
        print(f"🔍 عدد الفرق في الترتيب: {len(df)}")
        print("📊 ترتيب المجموعات:")
        
        group_winners = []
        runners_up = []
        
        # تجميع الفرق حسب المجموعة
        groups = {}
        for _, team in df.iterrows():
            group = team['group_char']
            if group not in groups:
                groups[group] = []
            groups[group].append(team)
        
        print(f"🎯 عدد المجموعات: {len(groups)}")
        
        # ترتيب الفرق داخل كل مجموعة
        for group, group_teams in groups.items():
            # ترتيب الفرق حسب النقاط، فارق الأهداف، الأهداف المسجلة
            group_teams_sorted = sorted(group_teams, 
                key=lambda x: (x['Pts'], x['GD'], x['GF']), 
                reverse=True)
            
            print(f"   🏆 المجموعة {group}:")
            for i, team in enumerate(group_teams_sorted):
                print(f"     {i+1}. {team['name_ar']} - {team['Pts']} نقطة (فارق: {team['GD']})")
            
            # إضافة المتصدر
            if len(group_teams_sorted) >= 1:
                winner = group_teams_sorted[0]
                group_winners.append({
                    'name': winner['name_ar'],
                    'name_en': winner['name_en'],
                    'group': group,
                    'points': winner['Pts'],
                    'goal_difference': winner['GD']
                })
                print(f"     ✅ المتصدر: {winner['name_ar']}")
            
            # إضافة المركز الثاني
            if len(group_teams_sorted) >= 2:
                runner = group_teams_sorted[1]
                runners_up.append({
                    'name': runner['name_ar'],
                    'name_en': runner['name_en'],
                    'group': group,
                    'points': runner['Pts'],
                    'goal_difference': runner['GD']
                })
                print(f"     ✅ المركز الثاني: {runner['name_ar']}")
        
        print(f"👑 المتصدرون: {[w['name'] for w in group_winners]}")
        print(f"🥈 المركز الثاني: {[r['name'] for r in runners_up]}")
        
        qualified_teams = group_winners + runners_up
        
        print(f"🎉 المجموع المتأهل: {len(qualified_teams)} فريق")
        
        return qualified_teams
        
    except Exception as e:
        print(f"❌ Error in get_qualified_teams_correct: {e}")
        traceback.print_exc()
        return []

def debug_group_standings():
    """دالة لفحص ترتيب المجموعات"""
    print("\n=== 🔍 فحص ترتيب المجموعات ===")
    
    df = get_group_standings()
    if df.empty:
        print("❌ لا توجد بيانات في ترتيب المجموعات")
        return False
    
    print(f"✅ عدد الفرق في الترتيب: {len(df)}")
    print("📋 عينة من البيانات:")
    print(df[['name_ar', 'group_char', 'Pts', 'GD', 'GF']].head(8))
    
    # التحقق من المجموعات
    groups = df['group_char'].unique()
    print(f"🎯 المجموعات الموجودة: {sorted(groups)}")
    
    # التحقق من وجود بيانات كافية في كل مجموعة
    for group in sorted(groups):
        group_teams = df[df['group_char'] == group]
        print(f"   المجموعة {group}: {len(group_teams)} فريق")
        for _, team in group_teams.iterrows():
            print(f"     - {team['name_ar']}: {team['Pts']} نقطة")
    
    return len(df) >= 32  # يجب أن يكون هناك 32 فريق على الأقل

def generate_round_of_16_correct():
    """توليد مباريات دور الـ16 بشكل صحيح حسب القواعد الرسمية"""
    try:
        print("\n=== 🚀 بدء توليد دور الـ16 ===")
        
        # فحص ترتيب المجموعات أولاً
        if not debug_group_standings():
            print("❌ ترتيب المجموعات غير مكتمل")
            return 0
        
        qualified_teams = get_qualified_teams_correct()
        
        if len(qualified_teams) < 16:
            print(f"❌ عدد الفرق المتأهلة غير كافي: {len(qualified_teams)} من 16")
            print("📋 الفرق المتأهلة:")
            for team in qualified_teams:
                print(f"   - {team['name']} (المجموعة {team['group']})")
            return 0
        
        # فصل المتصدرين عن المركز الثاني
        group_winners = [team for team in qualified_teams if team in [w for w in qualified_teams[:8]]]
        runners_up = [team for team in qualified_teams if team in [r for r in qualified_teams[8:]]]
        
        print(f"👑 المتصدرون ({len(group_winners)}): {[w['name'] for w in group_winners]}")
        print(f"🥈 المركز الثاني ({len(runners_up)}): {[r['name'] for r in runners_up]}")
        
        match_count = 0
        base_date = QDate.currentDate()
        
        # خلط الفرق
        random.shuffle(group_winners)
        random.shuffle(runners_up)
        
        used_runners = set()
        matches_created = []
        
        print("🎲 جاري توزيع المباريات...")
        
        for i, winner in enumerate(group_winners):
            suitable_runner = None
            
            # البحث عن مركز ثاني مناسب (من مجموعة مختلفة)
            for runner in runners_up:
                if (runner['name'] not in used_runners and 
                    runner['group'] != winner['group']):
                    suitable_runner = runner
                    break
            
            # إذا لم يوجد مركز ثاني مناسب، نأخذ أي مركز ثاني
            if suitable_runner is None:
                for runner in runners_up:
                    if runner['name'] not in used_runners:
                        suitable_runner = runner
                        break
            
            if suitable_runner:
                home_team = winner['name']
                away_team = suitable_runner['name']
                used_runners.add(suitable_runner['name'])
                
                match_date = base_date.addDays(i * 3).toString("yyyy-MM-dd")
                
                # توليد النتائج بشكل عشوائي
                home_goals = random.randint(0, 3)
                away_goals = random.randint(0, 2)
                
                winner_team = ""
                win_method = "normal"
                home_extra = 0
                away_extra = 0
                home_pen = 0
                away_pen = 0
                
                if home_goals > away_goals:
                    winner_team = home_team
                elif away_goals > home_goals:
                    winner_team = away_team
                else:
                    # وقت إضافي
                    home_extra = random.randint(0, 1)
                    away_extra = random.randint(0, 1)
                    if home_goals + home_extra > away_goals + away_extra:
                        winner_team = home_team
                        win_method = "extra_time"
                    elif away_goals + away_extra > home_goals + home_extra:
                        winner_team = away_team
                        win_method = "extra_time"
                    else:
                        # ركلات ترجيح
                        home_pen = random.randint(3, 5)
                        away_pen = random.randint(2, 4)
                        winner_team = home_team if home_pen > away_pen else away_team
                        win_method = "penalties"
                
                # إضافة المباراة
                if add_match(home_team, away_team, home_goals, away_goals, match_date, 
                           "Round of 16", 'single', 0, home_extra, away_extra, 
                           home_pen, away_pen, winner_team, win_method):
                    match_count += 1
                    matches_created.append(f"{home_team} vs {away_team} - الفائز: {winner_team}")
                    print(f"✅ مباراة دور الـ16: {home_team} ({winner['group']}) vs {away_team} ({suitable_runner['group']}) - الفائز: {winner_team}")
        
        print(f"🎉 تم توليد {match_count} مباراة في دور الـ16")
        print("📋 المباريات المُنشأة:")
        for match in matches_created:
            print(f"  - {match}")
        
        return match_count
        
    except Exception as e:
        print(f"❌ خطأ في توليد دور الـ16: {e}")
        traceback.print_exc()
        return 0
