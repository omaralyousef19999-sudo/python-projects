def get_qualified_teams_correct():
    """الحصول على الفرق المتأهلة حسب قواعد دوري الأبطال الحقيقية - المتصدرين والمركز الثاني"""
    try:
        df = get_group_standings()
        
        if df.empty:
            print("لا توجد بيانات للترتيب")
            return []
        
        # تجميع المتصدرين والمركز الثاني من كل مجموعة
        group_winners = []  # المتصدرين
        runners_up = []     # المركز الثاني
        
        for group in ['A','B','C','D','E','F','G','H']:
            group_teams = df[df['group_char'] == group].head(2)  # أول فريقين في المجموعة
            
            if len(group_teams) >= 1:
                group_winners.append({
                    'name': group_teams.iloc[0]['name_ar'],
                    'group': group
                })
            if len(group_teams) >= 2:
                runners_up.append({
                    'name': group_teams.iloc[1]['name_ar'],
                    'group': group
                })
        
        print(f"المتصدرون: {[w['name'] for w in group_winners]}")
        print(f"المركز الثاني: {[r['name'] for r in runners_up]}")
        
        if len(group_winners) < 8 or len(runners_up) < 8:
            print(f"عدد الفرق غير كافي: {len(group_winners)} متصدر و {len(runners_up)} مركز ثاني")
            return []
        
        # في دوري الأبطال: جميع المتصدرين والمركز الثاني يتأهلون مباشرة لدور الـ16
        qualified_teams = group_winners + runners_up
        
        print(f"المجموع المتأهل: {len(qualified_teams)} فريق")
        
        return qualified_teams
        
    except Exception as e:
        print(f"Error in get_qualified_teams_correct: {e}")
        traceback.print_exc()
        return []

