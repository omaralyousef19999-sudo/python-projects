    def populate_teams_table(self):
        df = get_all_teams()
        self.teams_table.setColumnCount(8)
        headers = ["الاسم العربي", "الاسم الإنجليزي", "الدولة عربي", "الدولة إنجليزي", "المجموعة", "الحالة", "محظور", "إجراءات"] if self.lang=="ar" else ["Arabic Name", "English Name", "Country (Ar)", "Country (En)", "Group", "Status", "Banned", "Actions"]
        self.teams_table.setHorizontalHeaderLabels(headers)
        self.teams_table.setRowCount(len(df))
        
        for i, row in df.iterrows():
            # بيانات الفريق
            self.teams_table.setItem(i, 0, QTableWidgetItem(str(row["name_ar"])))
            self.teams_table.setItem(i, 1, QTableWidgetItem(str(row["name_en"])))
            self.teams_table.setItem(i, 2, QTableWidgetItem(str(row["country_ar"])))
            self.teams_table.setItem(i, 3, QTableWidgetItem(str(row["country_en"])))
            self.teams_table.setItem(i, 4, QTableWidgetItem(str(row["group_char"])))
            
            # حالة الفريق
            status = "مقصي" if row.get("eliminated", 0) else "نشط"
            status_item = QTableWidgetItem(status)
            if row.get("eliminated", 0):
                status_item.setBackground(QColor(255, 100, 100, 150))  # أحمر للفرق المقصية
            else:
                status_item.setBackground(QColor(100, 255, 100, 150))  # أخضر للفرق النشطة
            self.teams_table.setItem(i, 5, status_item)
            
            # حالة الحظر
            banned_status = "نعم" if row.get("banned", 0) else "لا"
            banned_item = QTableWidgetItem(banned_status)
            if row.get("banned", 0):
                banned_item.setBackground(QColor(255, 0, 0, 150))  # أحمر للفرق المحظورة
            self.teams_table.setItem(i, 6, banned_item)
            
            # أزرار الإجراءات
            actions_widget = QWidget()
            actions_layout = QHBoxLayout(actions_widget)
            actions_layout.setContentsMargins(4, 4, 4, 4)
            
            # زر حذف الفريق
            delete_btn = QPushButton("حذف" if self.lang=="ar" else "Delete")
            delete_btn.setStyleSheet("background: #FF6B6B; color: white; padding: 5px; font-size: 12px;")
            delete_btn.clicked.connect(lambda checked, team=row["name_ar"]: self.delete_team_confirm(team))
            
            # زر حظر/فك الحظر
            ban_btn = QPushButton("حظر" if self.lang=="ar" else "Ban")
            if row.get("banned", 0):
                ban_btn.setText("فك الحظر" if self.lang=="ar" else "Unban")
                ban_btn.setStyleSheet("background: #FFA500; color: white; padding: 5px; font-size: 12px;")
            else:
                ban_btn.setStyleSheet("background: #FF6B6B; color: white; padding: 5px; font-size: 12px;")
            ban_btn.clicked.connect(lambda checked, team=row["name_ar"], current=row.get("banned", 0): self.toggle_ban_team(team, current))
            
            actions_layout.addWidget(delete_btn)
            actions_layout.addWidget(ban_btn)
            self.teams_table.setCellWidget(i, 7, actions_widget)
        
        self.teams_table.resizeColumnsToContents()

