def get_qualified_for_next_stage_correct(current_stage):
    """الحصول على الفرق المتأهلة للمرحلة التالية بناءً على نتائج المرحلة الحالية - الإصدار المصحح"""
    if current_stage == "Group Stage":
        qualified = get_qualified_teams_correct()
        return [team['name'] for team in qualified]  # إرجاع الأسماء فقط
    else:
        return get_winners_from_stage(current_stage)

