    def _add_knockout_and_close(self, dlg, home, away, hg, ag, home_extra, away_extra, 
                              home_pen, away_pen, date, stage, winner, win_method):
        if home and away and home != away:
            if add_match(home, away, hg, ag, date, stage, 'single', 0, 
                        home_extra, away_extra, home_pen, away_pen, winner, win_method):
                dlg.accept()
                self.populate_knockout_table()
                self.update_qualified_teams_display()
                QMessageBox.information(self, "تم", "تمت الإضافة")
            else:
                QMessageBox.warning(self, "خطأ", "فشل في إضافة المباراة")
        else:
            QMessageBox.warning(self, "خطأ", "اختر فريقين مختلفين")

    def advance_stage(self):
        current_stage = self.k_stage_combo.currentText()
        next_stage = ""
        
        if current_stage == "Round of 16":
            next_stage = "Quarter Final"
        elif current_stage == "Quarter Final":
            next_stage = "Semi Final"
        elif current_stage == "Semi Final":
            next_stage = "Final"
        else:
            QMessageBox.information(self, "تم", 
                "البطولة انتهت!")
            return
        
        winners = get_winners_from_stage(current_stage)
        
        if not winners:
            QMessageBox.warning(self, "تحذير",
                "لا توجد مباريات مكتملة في المرحلة الحالية")
            return
        
        all_teams = get_all_teams()["name_ar"].tolist()
        eliminated_teams = [team for team in all_teams if team not in winners]
        eliminate_teams(eliminated_teams)
        
        QMessageBox.information(self, "تم", 
            f"تم التقدم ل{next_stage}. الفرق المتأهلة: {', '.join(winners)}")
        
        self.k_stage_combo.setCurrentText(next_stage)
        self.update_qualified_teams_display()
        self.populate_knockout_table()

