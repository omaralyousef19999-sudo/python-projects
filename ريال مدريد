    c.execute("DROP TABLE IF EXISTS knockout_results")
    
    # إنشاء جدول الفرق مع الحقول الجديدة
    c.execute('''CREATE TABLE IF NOT EXISTS teams (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name_ar TEXT NOT NULL,
        name_en TEXT NOT NULL,
        country_ar TEXT,
        country_en TEXT,
        group_char TEXT,
        eliminated BOOLEAN DEFAULT 0,
        banned BOOLEAN DEFAULT 0,
        UNIQUE(name_ar, name_en)
    )''')
    
    # إنشاء جدول المباريات مع الحقول الجديدة للأشواط الإضافية
    c.execute('''CREATE TABLE IF NOT EXISTS matches (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        home_team TEXT,
        away_team TEXT,
        home_goals INTEGER,
        away_goals INTEGER,
        home_extra_time_goals INTEGER DEFAULT 0,
        away_extra_time_goals INTEGER DEFAULT 0,
