        h = self.h.currentText()
        a = self.a.currentText()
        stage = self.stage_combo.currentText()
        date = self.match_date.date().toString("yyyy-MM-dd")
        
        if h and a and h != a:
            if add_match(h, a, self.hg.value(), self.ag.value(), date, stage):
                QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", "تمت الإضافة" if self.lang=="ar" else "Added")
                self.populate_matches_table()
