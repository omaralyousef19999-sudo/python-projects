            "تأكيد" if self.lang=="ar" else "Confirm",
            f"هل تريد {action} الفريق {team_name}؟" if self.lang=="ar" else f"{action} team {team_name}?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply == QMessageBox.StandardButton.Yes:
            ban_team(team_name, new_status)
            status_text = "محظور" if new_status == 1 else "نشط"
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                f"تم {action} الفريق بنجاح" if self.lang=="ar" else f"Team {action.lower()}ed successfully")
