# ---------- Thread للتوليد التلقائي ----------
class GenerationThread(QThread):
    progress_updated = pyqtSignal(int)
    stage_updated = pyqtSignal(str)
    finished_signal = pyqtSignal(bool, str)

    def __init__(self):
        super().__init__()
        self.cancelled = False

    def run(self):
        try:
            total_matches = 0
            
            # 1. توليد دور المجموعات
            if self.cancelled: return
            self.stage_updated.emit("جاري توليد دور المجموعات...")
            group_matches = generate_all_group_matches()
            total_matches += group_matches
            self.progress_updated.emit(20)
            
            # 2. توليد دور الـ16
            if self.cancelled: return
            self.stage_updated.emit("جاري توليد دور الـ16...")
            round_of_16_matches = generate_round_of_16_correct()
            total_matches += round_of_16_matches
            self.progress_updated.emit(40)
            
            # 3. توليد ربع النهائي
            if self.cancelled: return
            self.stage_updated.emit("جاري توليد ربع النهائي...")
            quarter_matches = generate_knockout_stage_matches("Quarter Final")
            total_matches += quarter_matches
            self.progress_updated.emit(60)
            
            # 4. توليد نصف النهائي
            if self.cancelled: return
            self.stage_updated.emit("جاري توليد نصف النهائي...")
            semi_matches = generate_knockout_stage_matches("Semi Final")
            total_matches += semi_matches
            self.progress_updated.emit(80)
            
            # 5. توليد النهائي
            if self.cancelled: return
            self.stage_updated.emit("جاري توليد النهائي...")
            final_matches = generate_knockout_stage_matches("Final")
            total_matches += final_matches
            self.progress_updated.emit(100)
            
            if self.cancelled:
                self.finished_signal.emit(False, "تم إلغاء العملية")
            else:
                self.finished_signal.emit(True, f"تم توليد {total_matches} مباراة بنجاح!")
                
        except Exception as e:
            self.finished_signal.emit(False, f"حدث خطأ: {str(e)}")

    def cancel(self):
        self.cancelled = True

