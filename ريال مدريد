    def get_stage_name_ar(self, stage_name):
        """الحصول على اسم المرحلة بالعربية"""
        stage_names = {
            "Group Stage": "دور المجموعات",
            "Round of 16": "دور الـ16", 
            "Quarter Final": "ربع النهائي",
            "Semi Final": "نصف النهائي",
            "Final": "النهائي"
        }
        return stage_names.get(stage_name, stage_name)

    def reset_knockouts(self):
        reply = QMessageBox.question(self, 
            "تأكيد" if self.lang=="ar" else "Confirm",
            "هل تريد إعادة تعيين جميع مباريات الإقصائيات؟" if self.lang=="ar" else "Reset all knockout matches?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        
        if reply == QMessageBox.StandardButton.Yes:
            conn = get_db_connection()
            c = conn.cursor()
            c.execute("DELETE FROM matches WHERE stage != 'Group Stage'")
            c.execute("DELETE FROM knockout_results")
            c.execute("UPDATE teams SET eliminated = 0")
            conn.commit()
            conn.close()
            self.populate_knockout_table()
            self.update_qualified_teams_display()
            QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", 
                "تم إعادة تعيين الإقصائيات" if self.lang=="ar" else "Knockouts reset successfully")

    def populate_knockout_table(self):
        try:
            stage = self.k_stage_combo.currentText()
            df = get_matches(stage)
            self.k_table.setColumnCount(12)
            headers = ["المضيف", "الضيف", "أهداف", "أهداف", "وقت إضافي", "وقت إضافي", "ركلات", "ركلات", "الفائز", "طريقة الفوز", "التاريخ", "إجراءات"] if self.lang=="ar" else ["Home","Away","HG","AG","ET-H","ET-A","Pen-H","Pen-A","Winner","Win Method","Date","Actions"]
            self.k_table.setHorizontalHeaderLabels(headers)
            self.k_table.setRowCount(len(df))
            
            for i, row in df.iterrows():
                self.k_table.setItem(i, 0, QTableWidgetItem(str(row["home_team"])))
                self.k_table.setItem(i, 1, QTableWidgetItem(str(row["away_team"])))
                self.k_table.setItem(i, 2, QTableWidgetItem(str(row["home_goals"])))
                self.k_table.setItem(i, 3, QTableWidgetItem(str(row["away_goals"])))
                self.k_table.setItem(i, 4, QTableWidgetItem(str(row.get("home_extra_time_goals", 0))))
                self.k_table.setItem(i, 5, QTableWidgetItem(str(row.get("away_extra_time_goals", 0))))
                self.k_table.setItem(i, 6, QTableWidgetItem(str(row.get("home_penalties", 0))))
                self.k_table.setItem(i, 7, QTableWidgetItem(str(row.get("away_penalties", 0))))
                
                winner = row.get("winner", "")
                win_method = row.get("win_method", "normal")
                
                win_method_text = ""
                if self.lang == "ar":
                    if win_method == "normal":
                        win_method_text = "الوقت الأصلي"
                    elif win_method == "extra_time":
                        win_method_text = "وقت إضافي"
                    elif win_method == "penalties":
                        win_method_text = "ركلات ترجيح"
                else:
                    win_method_text = win_method.capitalize()
                
                self.k_table.setItem(i, 8, QTableWidgetItem(winner))
                self.k_table.setItem(i, 9, QTableWidgetItem(win_method_text))
                self.k_table.setItem(i, 10, QTableWidgetItem(str(row["date"])))
                
                delete_btn = QPushButton("حذف" if self.lang=="ar" else "Delete")
                delete_btn.setStyleSheet("background: #FF6B6B; color: white; padding: 5px; font-size: 12px;")
                delete_btn.clicked.connect(lambda checked, mid=row["id"]: self.delete_match_confirm(mid))
                
                cell_widget = QWidget()
                cell_layout = QHBoxLayout(cell_widget)
                cell_layout.addWidget(delete_btn)
                cell_layout.setContentsMargins(4, 4, 4, 4)
                self.k_table.setCellWidget(i, 11, cell_widget)
            
            self.k_table.resizeColumnsToContents()
        except Exception as e:
            print(f"Error in populate_knockout_table: {e}")

