def eliminate_teams(team_names):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # إعادة تعيين جميع الفرق أولاً
        c.execute("UPDATE teams SET eliminated = 0")
        # ثم إقصاء الفرق المحددة
        for team in team_names:
            c.execute("UPDATE teams SET eliminated = 1 WHERE name_ar = ? OR name_en = ?", (team, team))
        conn.commit()
    except Exception as e:
        print(f"Error in eliminate_teams: {e}")
    finally:
        conn.close()

def ban_team(team_name, ban_status):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("UPDATE teams SET banned = ? WHERE name_ar = ? OR name_en = ?", (ban_status, team_name, team_name))
        conn.commit()
    except Exception as e:
        print(f"Error in ban_team: {e}")
    finally:
        conn.close()

def delete_team(team_name):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # حذف المباريات المرتبطة أولاً
        c.execute("DELETE FROM matches WHERE home_team = ? OR away_team = ?", (team_name, team_name))
        # ثم حذف الفريق
        c.execute("DELETE FROM teams WHERE name_ar = ? OR name_en = ?", (team_name, team_name))
        conn.commit()
        return True
    except Exception as e:
        print(f"Error in delete_team: {e}")
        return False
    finally:
        conn.close()

def delete_match(match_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        # حذف من جدول النتائج أولاً
        c.execute("DELETE FROM knockout_results WHERE match_id = ?", (match_id,))
        # ثم حذف من جدول المباريات
        c.execute("DELETE FROM matches WHERE id = ?", (match_id,))
        conn.commit()
        return True
    except Exception as e:
        print(f"Error in delete_match: {e}")
        return False
    finally:
        conn.close()

def reset_tournament():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("DELETE FROM matches")
        c.execute("DELETE FROM knockout_results")
        c.execute("UPDATE teams SET eliminated = 0, banned = 0")
        conn.commit()
    except Exception as e:
        print(f"Error in reset_tournament: {e}")
    finally:
        conn.close()

def get_qualified_teams():
    """الحصول على الفرق المتأهلة للإقصائيات (أفضل 16 فريق)"""
    standings = get_standings()
    return standings.head(16)

def get_winners_from_stage(stage):
    """الحصول على الفائزين من مرحلة معينة"""
    conn = sqlite3.connect(DB_PATH)
    try:
        df = pd.read_sql_query("""
            SELECT winner FROM matches 
            WHERE stage = ? AND winner IS NOT NULL
            GROUP BY winner
        """, conn, params=(stage,))
        return df["winner"].tolist()
    except Exception as e:
        print(f"Error in get_winners_from_stage: {e}")
        return []
    finally:
        conn.close()

def get_qualified_for_next_stage(current_stage):
    """الحصول على الفرق المتأهلة للمرحلة التالية بناءً على نتائج المرحلة الحالية"""
    if current_stage == "Group Stage":
        return get_qualified_teams()["name_ar"].tolist()
    else:
        return get_winners_from_stage(current_stage)

