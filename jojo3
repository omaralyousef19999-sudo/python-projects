            ),
            SizedBox(height: 16),

            Text(
              '📋 ${controller.isArabic() ? 'خطوات التمرين' : 'Exercise Steps'}:',
              style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)
            ),
            SizedBox(height: 8),
            ...exercise.steps.map((step) => Padding(
              padding: EdgeInsets.symmetric(vertical: 4),
              child: Row(
                children: [
                  Icon(Icons.check_circle_outline, color: controller.currentAccentColor.value, size: 16),
                  SizedBox(width: 8),
