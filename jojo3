class AIChatScreen extends StatelessWidget {
  final MainController controller;
  final TextEditingController messageController = TextEditingController();

  AIChatScreen({Key? key, required this.controller}) : super(key: key);

  @override
  Widget build(BuildContext context) {
    return Obx(() => Padding(
      padding: EdgeInsets.all(16),
      child: Column(
        children: [
          Container(
            padding: EdgeInsets.all(12),
            decoration: BoxDecoration(
              color: controller.currentCardColor.value,
              borderRadius: BorderRadius.circular(16),
              border: Border.all(color: controller.currentAccentColor.value.withOpacity(0.3)),
            ),
            child: Row(
              children: [
                Icon(Icons.auto_awesome, color: controller.currentAccentColor.value),
                SizedBox(width: 8),
                Text(
                  '🧠 ${controller.isArabic() ? 'مساعد' : 'Assistant'} ${controller.currentUser.value?.name ?? (controller.isArabic() ? 'الذكي' : 'Smart')}',
                  style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold),
                ),
                Spacer(),
                Container(
                  padding: EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: controller.currentAccentColor.value.withOpacity(0.2),
                    borderRadius: BorderRadius.circular(12),
                  ),
                  child: Text(
                    controller.isArabic() ? 'متصل' : 'Online',
                    style: TextStyle(color: controller.currentAccentColor.value, fontSize: 10)
                  ),
                ),
              ],
            ),
          ),
          SizedBox(height: 12),

          Expanded(
            child: Obx(() {
              if (controller.aiMessages.isEmpty) {
                return Center(
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Icon(Icons.chat, color: AppColors.metallicGray, size: 60),
                      SizedBox(height: 16),
                      Text(
                        controller.isArabic() ? 'اسألني عن الصحة واللياقة' : 'Ask me about health and fitness',
                        style: TextStyle(color: AppColors.metallicGray),
                      ),
                      SizedBox(height: 8),
                      Text(
                        controller.isArabic() 
                          ? 'يمكنني مساعدتك في التمارين، التغذية، والنوم'
                          : 'I can help you with exercises, nutrition, and sleep',
                        style: TextStyle(color: AppColors.metallicGray, fontSize: 12),
                      ),
                    ],
                  ),
                );
              }
              return ListView.builder(
                reverse: true,
                itemCount: controller.aiMessages.length + (controller.aiLoading.value ? 1 : 0),
                itemBuilder: (context, index) {
                  if (index == controller.aiMessages.length && controller.aiLoading.value) {
                    return _buildMessage(
                      controller.isArabic() ? 'جار التفكير...' : 'Thinking...',
                      'ai'
                    );
                  }
                  var message = controller.aiMessages.reversed.toList()[index];
                  return _buildMessage(message['message']!, message['sender']!);
                },
              );
            }),
          ),

          Container(
            decoration: BoxDecoration(
              color: controller.currentCardColor.value,
              borderRadius: BorderRadius.circular(30),
              border: Border.all(color: AppColors.metallicGray),
            ),
            child: Row(
              children: [
                Expanded(
                  child: TextField(
                    controller: messageController,
                    style: TextStyle(color: Colors.white),
                    decoration: InputDecoration(
                      hintText: controller.isArabic() 
                        ? 'اسألني عن الصحة واللياقة...' 
                        : 'Ask me about health and fitness...',
                      hintStyle: TextStyle(color: AppColors.metallicGray),
                      border: InputBorder.none,
                      contentPadding: EdgeInsets.symmetric(horizontal: 16),
                    ),
                    onSubmitted: (value) {
                      if (value.isNotEmpty) {
                        controller.askAI(value);
                        messageController.clear();
                      }
                    },
                  ),
                ),
                IconButton(
                  icon: Icon(Icons.send, color: controller.currentAccentColor.value),
                  onPressed: () {
                    if (messageController.text.isNotEmpty) {
                      controller.askAI(messageController.text);
                      messageController.clear();
                    }
                  },
                ),
              ],
            ),
          ),
        ],
      ),
    ));
  }

  Widget _buildMessage(String text, String sender) {
    bool isUser = sender == 'user';
    return Align(
      alignment: isUser ? Alignment.centerRight : Alignment.centerLeft,
      child: Container(
        margin: EdgeInsets.only(bottom: 8),
        padding: EdgeInsets.symmetric(horizontal: 16, vertical: 10),
        decoration: BoxDecoration(
          color: isUser ? controller.currentAccentColor.value : controller.currentCardColor.value,
          borderRadius: BorderRadius.only(
            topLeft: Radius.circular(16),
            topRight: Radius.circular(16),
            bottomLeft: isUser ? Radius.circular(16) : Radius.circular(0),
            bottomRight: isUser ? Radius.circular(0) : Radius.circular(16),
          ),
          border: isUser ? null : Border.all(color: AppColors.metallicGray),
        ),
        child: Text(
          text,
          style: TextStyle(
            color: isUser ? AppColors.primaryBlack : AppColors.whiteTransparent,
          ),
        ),
      ),
    );
  }
}

