  Color _getBMIColor(String category) {
    if (category == 'نحيف') return AppColors.warningYellow;
    if (category == 'طبيعي') return AppColors.successGreen;
    if (category == 'زائد') return AppColors.hotOrange;
    return AppColors.dangerRed;
  }

  String _getBMICategoryEnglish(String category) {
    if (category == 'نحيف') return 'Underweight';
    if (category == 'طبيعي') return 'Normal';
    if (category == 'زائد') return 'Overweight';
    return 'Obese';
  }
