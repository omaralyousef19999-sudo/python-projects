  // ========== حساب السعرات ==========
  int calculateCaloriesBurned(Exercise exercise) {
    if (currentUser.value == null) return exercise.duration * exercise.caloriesPerMinute;
    double weight = currentUser.value!.weight;
    double met = 0;

    if (exercise.type == 'كارديو') {
      met = 6.0;
    } else if (exercise.type == 'قوة') {
      met = 5.0;
    } else if (exercise.type == 'HIIT') {
      met = 8.0;
    } else if (exercise.type == 'يوغا') {
      met = 2.5;
    } else {
      met = 3.0;
    }

    return ((met * 3.5 * weight) / 200 * exercise.duration).toInt();
  }

