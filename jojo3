  Future<bool> login(String email, String password) async {
    isLoading.value = true;
    try {
      SharedPreferences prefs = await SharedPreferences.getInstance();
      String? usersJson = prefs.getString('users');
      
      if (usersJson == null) {
        isLoading.value = false;
        Get.snackbar(
          isArabic() ? 'خطأ' : 'Error',
          isArabic() ? 'لا يوجد مستخدمين مسجلين' : 'No registered users',
          backgroundColor: AppColors.dangerRed,
        );
        return false;
      }

      List<dynamic> usersList = jsonDecode(usersJson);
      
      User? foundUser;
      for (var userData in usersList) {
        if (userData['email'] == email && userData['password'] == password) {
          foundUser = User.fromJson(userData);
          break;
        }
      }

      if (foundUser == null) {
        isLoading.value = false;
        Get.snackbar(
          isArabic() ? 'خطأ' : 'Error',
          isArabic() ? '❌ البريد الإلكتروني أو كلمة المرور غير صحيحة' : '❌ Invalid email or password',
          backgroundColor: AppColors.dangerRed,
          duration: Duration(seconds: 3),
        );
        return false;
      }

      foundUser.lastLoginTime = DateTime.now().toString();
      
      for (int i = 0; i < usersList.length; i++) {
        if (usersList[i]['id'] == foundUser!.id) {
          usersList[i] = foundUser.toJson();
          break;
        }
      }
      
      await prefs.setString('users', jsonEncode(usersList));
      await prefs.setString('currentUser', jsonEncode(foundUser.toJson()));
      
      currentUser.value = foundUser;
      isLoggedIn.value = true;
      _loadUserData();
      _loadUserAIContext();
      
      isLoading.value = false;
      Get.snackbar(
        isArabic() ? '🎉 مرحباً' : '🎉 Welcome',
        isArabic() ? 'أهلاً بك ${foundUser.name}' : 'Welcome ${foundUser.name}',
        backgroundColor: AppColors.successGreen,
        duration: Duration(seconds: 2),
      );
      return true;
    } catch (e) {
      isLoading.value = false;
      Get.snackbar(
        isArabic() ? 'خطأ' : 'Error',
        isArabic() ? 'حدث خطأ أثناء تسجيل الدخول: ${e.toString()}' : 'Error during login: ${e.toString()}',
        backgroundColor: AppColors.dangerRed,
        duration: Duration(seconds: 3),
      );
      return false;
    }
  }

  Future<bool> register(Map<String, dynamic> userData) async {
    isLoading.value = true;
    try {
      SharedPreferences prefs = await SharedPreferences.getInstance();
      String? usersJson = prefs.getString('users');
      List<User> users = [];
      if (usersJson != null) {
        List<dynamic> usersList = jsonDecode(usersJson);
        users = usersList.map((u) => User.fromJson(u)).toList();
      }

      for (var user in users) {
        if (user.email == userData['email']) {
          isLoading.value = false;
          Get.snackbar(
            isArabic() ? 'خطأ' : 'Error',
            isArabic() ? '❌ البريد الإلكتروني مستخدم بالفعل' : '❌ Email already in use',
            backgroundColor: AppColors.dangerRed,
            duration: Duration(seconds: 3),
          );
          return false;
        }
      }

      User newUser = User(
        id: DateTime.now().millisecondsSinceEpoch.toString(),
        name: userData['name'],
        email: userData['email'],
        password: userData['password'],
        gender: userData['gender'],
        age: userData['age'],
        height: userData['height'],
        weight: userData['weight'],
        fitnessLevel: userData['fitnessLevel'] ?? 'مبتدئ',
        goal: userData['goal'] ?? 'لياقة عامة',
        lastLoginTime: DateTime.now().toString(),
      );

      users.add(newUser);
      await prefs.setString('users', jsonEncode(users.map((u) => u.toJson()).toList()));
      await prefs.setString('currentUser', jsonEncode(newUser.toJson()));
      
      currentUser.value = newUser;
      isLoggedIn.value = true;
      _loadUserData();
      
      isLoading.value = false;
      Get.snackbar(
        isArabic() ? '🎉 تهانينا' : '🎉 Congratulations',
        isArabic() ? 'تم إنشاء حسابك بنجاح!' : 'Account created successfully!',
        backgroundColor: AppColors.successGreen,
        duration: Duration(seconds: 2),
      );
      return true;
    } catch (e) {
      isLoading.value = false;
      Get.snackbar(
        isArabic() ? 'خطأ' : 'Error',
        isArabic() ? 'حدث خطأ أثناء التسجيل: ${e.toString()}' : 'Error during registration: ${e.toString()}',
        backgroundColor: AppColors.dangerRed,
        duration: Duration(seconds: 3),
      );
      return false;
    }
  }

