                        ],
                      ),
                      Text(
                        '${exercise.level} • ${exercise.bodyPart}',
                        style: TextStyle(color: AppColors.metallicGray),
                      ),
                    ],
                  ),
                ),
              ],
            ),
            SizedBox(height: 16),

            Wrap(
              spacing: 8,
              children: [
                _buildStatChip('⏱️ ${exercise.duration} ${controller.isArabic() ? 'د' : 'min'}', AppColors.electricBlue),
                _buildStatChip('⭐ ${exercise.rating}', AppColors.neonPink),
                _buildStatChip('🔥 $caloriesBurned ${controller.isArabic() ? 'سعر' : 'cal'}', AppColors.hotOrange),
