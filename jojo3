  // ========== إدارة الوضع الليلي والصباحي ==========
  void updateThemeBasedOnTime() {
    var hour = DateTime.now().hour;
    
    if (hour >= 5 && hour < 12) {
      // وضع الصباح
      currentTheme.value = 'morning';
      isMorningMode.value = true;
      isNightMode.value = false;
      greetingMessage.value = isArabic() ? '🌅 صباح الخير' : '🌅 Good Morning';
      currentBackgroundColor.value = Color(0xFF1A2A3A);
      currentCardColor.value = Color(0xFF2A3A4A);
      currentAccentColor.value = Color(0xFFFFB74D);
    } else if (hour >= 12 && hour < 18) {
      // وضع المساء
      currentTheme.value = 'evening';
      isMorningMode.value = false;
      isNightMode.value = false;
      greetingMessage.value = isArabic() ? '🌤️ مساء الخير' : '🌤️ Good Evening';
      currentBackgroundColor.value = Color(0xFF2A1A0A);
      currentCardColor.value = Color(0xFF3A2A1A);
      currentAccentColor.value = Color(0xFFFF6B00);
    } else {
      // وضع الليل
      currentTheme.value = 'night';
      isMorningMode.value = false;
      isNightMode.value = true;
      greetingMessage.value = isArabic() ? '🌙 مساء النور' : '🌙 Good Night';
      currentBackgroundColor.value = Color(0xFF0A0A1A);
      currentCardColor.value = Color(0xFF1A1A2A);
      currentAccentColor.value = Color(0xFF7C4DFF);
    }
    
    SharedPreferences.getInstance().then((prefs) {
      prefs.setString('theme_mode', currentTheme.value);
    });
  }

  void setThemeMode(String mode) {
    currentTheme.value = mode;
    
    switch(mode) {
      case 'morning':
        isMorningMode.value = true;
        isNightMode.value = false;
        greetingMessage.value = isArabic() ? '🌅 صباح الخير' : '🌅 Good Morning';
        currentBackgroundColor.value = Color(0xFF1A2A3A);
        currentCardColor.value = Color(0xFF2A3A4A);
        currentAccentColor.value = Color(0xFFFFB74D);
        break;
      case 'evening':
        isMorningMode.value = false;
        isNightMode.value = false;
        greetingMessage.value = isArabic() ? '🌤️ مساء الخير' : '🌤️ Good Evening';
        currentBackgroundColor.value = Color(0xFF2A1A0A);
        currentCardColor.value = Color(0xFF3A2A1A);
        currentAccentColor.value = Color(0xFFFF6B00);
        break;
      case 'night':
        isMorningMode.value = false;
        isNightMode.value = true;
        greetingMessage.value = isArabic() ? '🌙 مساء النور' : '🌙 Good Night';
        currentBackgroundColor.value = Color(0xFF0A0A1A);
        currentCardColor.value = Color(0xFF1A1A2A);
        currentAccentColor.value = Color(0xFF7C4DFF);
        break;
    }
    
    SharedPreferences.getInstance().then((prefs) {
      prefs.setString('theme_mode', mode);
    });
  }

