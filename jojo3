  // ========== المساعد الذكي (AI) ==========
  Future<void> askAI(String question) async {
    if (currentUser.value == null) {
      Get.snackbar(
        isArabic() ? 'خطأ' : 'Error',
        isArabic() ? 'يرجى تسجيل الدخول أولاً' : 'Please login first',
        backgroundColor: AppColors.dangerRed,
      );
      return;
    }

    aiLoading.value = true;
    aiMessages.add({'sender': 'user', 'message': question});
    _saveAIContext();

    try {
      String response = _getPersonalizedAIResponse(question);
      await Future.delayed(Duration(milliseconds: 800));
      aiMessages.add({'sender': 'ai', 'message': response});
      aiLoading.value = false;
      _saveAIContext();
      await speakCommand(response);
    } catch (e) {
      aiMessages.add({'sender': 'ai', 'message': isArabic() ? 'عذراً، حدث خطأ. حاول مرة أخرى.' : 'Sorry, an error occurred. Try again.'});
      aiLoading.value = false;
      _saveAIContext();
    }
  }

  String _getPersonalizedAIResponse(String question) {
    if (currentUser.value == null) {
      return isArabic() ? 'مرحباً! سجل الدخول أولاً للحصول على نصائح مخصصة.' : 'Hello! Login first to get personalized advice.';
    }

    User user = currentUser.value!;
    String q = question.toLowerCase();
    
    String userContext = 'مستخدم يدعى ${user.name}، عمره ${user.age} سنة، ';
    userContext += 'مستوى لياقته ${user.fitnessLevel}، هدفه ${user.goal}، ';
    userContext += 'وزنه ${user.weight} كغ، طوله ${user.height} سم.';
    
    userAIContext.value['last_question'] = question;
    userAIContext.value['user_context'] = userContext;
    _saveAIContext();

    if (q.contains('تمرين') || q.contains('رياضة')) {
      return isArabic() 
        ? 'مرحباً ${user.name}! بناءً على هدفك (${user.goal}) ومستواك (${user.fitnessLevel})، أنصحك بتمارين HIIT لمدة 20 دقيقة، فهي ممتازة لحرق الدهون وبناء اللياقة.'
        : 'Hello ${user.name}! Based on your goal (${user.goal}) and level (${user.fitnessLevel}), I recommend HIIT exercises for 20 minutes, they are great for burning fat and building fitness.';
    } else if (q.contains('غذاء') || q.contains('أكل') || q.contains('طعام')) {
      double proteinNeeded = user.weight * 1.6;
      return isArabic()
        ? '${user.name}، بناءً على وزنك (${user.weight} كغ) تحتاج حوالي ${proteinNeeded.toInt()} غرام بروتين يومياً. تناول الدجاج والسمك مع الخضار الورقية والحبوب الكاملة.'
        : '${user.name}, based on your weight (${user.weight} kg) you need about ${proteinNeeded.toInt()} grams of protein daily. Eat chicken and fish with leafy vegetables and whole grains.';
    } else if (q.contains('نوم')) {
      return isArabic()
        ? 'احرص على النوم 7-8 ساعات يومياً لتحسين الأداء الرياضي وبناء العضلات. جرب النوم في نفس الوقت كل يوم.'
        : 'Aim for 7-8 hours of sleep daily to improve athletic performance and build muscle. Try to sleep at the same time every day.';
    } else if (q.contains('ماء')) {
      double waterNeeded = user.weight * 0.033;
      return isArabic()
        ? 'بناءً على وزنك، تحتاج شرب ${waterNeeded.toStringAsFixed(1)} لتر من الماء يومياً، وزعها على مدار اليوم.'
        : 'Based on your weight, you need to drink ${waterNeeded.toStringAsFixed(1)} liters of water daily, spread throughout the day.';
    } else if (q.contains('وزن')) {
      double bmr = user.bmr;
      double caloriesNeeded = user.dailyCalories('متوسط');
      return isArabic()
        ? '${user.name}، معدل الأيض الأساسي لديك هو ${bmr.toInt()} سعر، وتحتاج حوالي ${caloriesNeeded.toInt()} سعر يومياً للحفاظ على وزنك. لإنقاص الوزن، قلل السعرات بـ 300-500 سعر يومياً.'
        : '${user.name}, your BMR is ${bmr.toInt()} calories, and you need about ${caloriesNeeded.toInt()} calories daily to maintain your weight. To lose weight, reduce calories by 300-500 calories daily.';
    } else if (q.contains('عضلات')) {
      return isArabic()
        ? 'للبناء العضلات، ركز على تمارين المقاومة 3-4 مرات أسبوعياً مع زيادة البروتين في نظامك الغذائي إلى ${(user.weight * 1.8).toInt()} غرام يومياً.'
        : 'To build muscle, focus on resistance exercises 3-4 times a week with increased protein in your diet to ${(user.weight * 1.8).toInt()} grams daily.';
    } else if (q.contains('تقدم') || q.contains('تحسن')) {
      int exercisesDone = user.exerciseHistory.length;
      return isArabic()
        ? '${user.name}، لقد أنجزت $exercisesDone تمريناً حتى الآن! استمر بنفس المستوى وستحقق أهدافك قريباً 💪'
        : '${user.name}, you have completed $exercisesDone exercises so far! Keep up the same level and you will achieve your goals soon 💪';
    } else {
      return isArabic()
        ? 'مرحباً ${user.name}! أنا مساعدك الذكي للصحة واللياقة. اسألني عن التمارين، التغذية، النوم، التقدم، أو أي سؤال صحي آخر.'
        : 'Hello ${user.name}! I am your smart health and fitness assistant. Ask me about exercises, nutrition, sleep, progress, or any other health question.';
    }
  }

  // ========== الإشعارات ==========
  Future<void> sendLocalNotification(String title, String body) async {
    const AndroidNotificationDetails androidPlatformChannelSpecifics =
        AndroidNotificationDetails(
      'fitness_channel',
      'قناة اللياقة',
      importance: Importance.max,
      priority: Priority.high,
    );
    const NotificationDetails platformChannelSpecifics =
        NotificationDetails(android: androidPlatformChannelSpecifics);

    await flutterLocalNotificationsPlugin.show(
      0,
      title,
      body,
      platformChannelSpecifics,
    );
  }

  void scheduleDailyReminders() async {
    await sendLocalNotification(
      isArabic() ? '🏋️ وقت التمرين!' : '🏋️ Workout Time!',
      isArabic() ? 'حان وقت تمارينك اليومية، استعد للحركة!' : 'Time for your daily workout, get ready to move!'
    );
    await Future.delayed(Duration(seconds: 2));
    await sendLocalNotification(
      isArabic() ? '💧 اشرب الماء!' : '💧 Drink Water!',
      isArabic() ? 'تذكر شرب كوب من الماء للحفاظ على الترطيب.' : 'Remember to drink a glass of water to stay hydrated.'
    );
    await Future.delayed(Duration(seconds: 2));
    await sendLocalNotification(
      isArabic() ? '🍽️ وقت الوجبة!' : '🍽️ Meal Time!',
      isArabic() ? 'تناول وجبة صحية متوازنة الآن.' : 'Eat a healthy balanced meal now.'
    );
  }

  // ========== مساعدة التنقل ==========
  void changePage(int index) {
    currentPage.value = index;
  }
}

