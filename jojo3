                        style: TextStyle(
                          color: isConsumed ? AppColors.metallicGray : Colors.white,
                          fontWeight: FontWeight.bold,
                          decoration: isConsumed ? TextDecoration.lineThrough : null,
                        ),
                      ),
                    ),
                    if (isConsumed)
                      Icon(Icons.check_circle, color: AppColors.successGreen, size: 16),
                  ],
                ),
                Text('${meal.calories.toInt()} ${controller.isArabic() ? 'سعر' : 'cal'} • P:${meal.protein}g C:${meal.carbs}g F:${meal.fat}g',
                    style: TextStyle(color: AppColors.metallicGray, fontSize: 12)),
                if (meal.description.isNotEmpty)
                  Text(meal.description, style: TextStyle(color: AppColors.metallicGray, fontSize: 11)),
              ],
            ),
          ),
          if (!isConsumed)
            GestureDetector(
              onTap: () {
                controller.addMealToHistory(meal);
              },
              child: Container(
                padding: EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                decoration: BoxDecoration(
                  color: controller.currentAccentColor.value,
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Text(
                  controller.isArabic() ? 'أضف' : 'Add',
                  style: TextStyle(color: Colors.black, fontWeight: FontWeight.bold)
                ),
              ),
            ),
        ],
      ),
    );
  }

  Color _getMealTypeColor(String type) {
    if (type == 'فطور' || type == 'Breakfast') return AppColors.warningYellow;
    if (type == 'غداء' || type == 'Lunch') return AppColors.hotOrange;
    if (type == 'عشاء' || type == 'Dinner') return AppColors.electricBlue;
    return AppColors.neonPink;
  }

  IconData _getMealTypeIcon(String type) {
    if (type == 'فطور' || type == 'Breakfast') return Icons.free_breakfast;
    if (type == 'غداء' || type == 'Lunch') return Icons.lunch_dining;
    if (type == 'عشاء' || type == 'Dinner') return Icons.dinner_dining;
    return Icons.cake;
  }
}

