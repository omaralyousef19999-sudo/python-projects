class User {
  String id;
  String name;
  String email;
  String password;
  String gender;
  int age;
  double height;
  double weight;
  String fitnessLevel;
  String goal;
  int dailySteps;
  double dailyCaloriesConsumed;
  List<Map<String, dynamic>> exerciseHistory;
  List<Map<String, dynamic>> mealHistory;
  String lastLoginTime;

  User({
    required this.id,
    required this.name,
    required this.email,
    required this.password,
    required this.gender,
    required this.age,
    required this.height,
    required this.weight,
    this.fitnessLevel = 'مبتدئ',
    this.goal = 'لياقة عامة',
    this.dailySteps = 0,
    this.dailyCaloriesConsumed = 0,
    this.exerciseHistory = const [],
    this.mealHistory = const [],
    this.lastLoginTime = '',
  });

  double get bmi {
    double heightInMeters = height / 100;
    return weight / (heightInMeters * heightInMeters);
  }

  String get bmiCategory {
    double value = bmi;
    if (value < 18.5) return 'نحيف';
    if (value < 25) return 'طبيعي';
    if (value < 30) return 'زائد';
    return 'سمنة';
  }

  double get bmr {
    double bmrValue = (10 * weight) + (6.25 * height) - (5 * age);
    if (gender == 'ذكر') {
      bmrValue += 5;
    } else {
      bmrValue -= 161;
    }
    return bmrValue;
  }

  double dailyCalories(String activityLevel) {
    double factor;
    if (activityLevel == 'قليل') {
      factor = 1.2;
    } else if (activityLevel == 'خفيف') {
      factor = 1.375;
    } else if (activityLevel == 'متوسط') {
      factor = 1.55;
    } else if (activityLevel == 'نشط') {
      factor = 1.725;
    } else {
      factor = 1.9;
    }
    return bmr * factor;
  }

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'name': name,
      'email': email,
      'password': password,
      'gender': gender,
      'age': age,
      'height': height,
      'weight': weight,
      'fitnessLevel': fitnessLevel,
      'goal': goal,
      'dailySteps': dailySteps,
      'dailyCaloriesConsumed': dailyCaloriesConsumed,
      'exerciseHistory': exerciseHistory,
      'mealHistory': mealHistory,
      'lastLoginTime': lastLoginTime,
    };
  }

  factory User.fromJson(Map<String, dynamic> json) {
    return User(
      id: json['id'],
      name: json['name'],
      email: json['email'],
      password: json['password'],
      gender: json['gender'],
      age: json['age'],
      height: json['height'],
      weight: json['weight'],
      fitnessLevel: json['fitnessLevel'] ?? 'مبتدئ',
      goal: json['goal'] ?? 'لياقة عامة',
      dailySteps: json['dailySteps'] ?? 0,
      dailyCaloriesConsumed: json['dailyCaloriesConsumed'] ?? 0,
      exerciseHistory: json['exerciseHistory']?.cast<Map<String, dynamic>>() ?? [],
      mealHistory: json['mealHistory']?.cast<Map<String, dynamic>>() ?? [],
      lastLoginTime: json['lastLoginTime'] ?? '',
    );
  }
}

