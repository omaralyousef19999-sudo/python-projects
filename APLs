// ========== التطبيق الرئيسي ==========
class WeatherApp extends StatelessWidget {
  const WeatherApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: '🌤️ الطقس',
      theme: ThemeData(
        colorScheme: ColorScheme.fromSeed(seedColor: Colors.blue),
        useMaterial3: true,
      ),
      home: const CityInputScreen(),
      debugShowCheckedModeBanner: false,
    );
  }
}

// ========== نموذج بيانات الطقس ==========
class WeatherModel {
  final String cityName;
  final double temperature;
  final double feelsLike;
  final int humidity;
  final double windSpeed;
  final String description;
  final String iconCode;
  final DateTime timestamp;

  WeatherModel({
    required this.cityName,
    required this.temperature,
    required this.feelsLike,
    required this.humidity,
    required this.windSpeed,
    required this.description,
    required this.iconCode,
    required this.timestamp,
  });

  factory WeatherModel.fromJson(Map<String, dynamic> json) {
    final main = json['main'];
    final weather = json['weather'][0];
    final wind = json['wind'];

    return WeatherModel(
      cityName: json['name'] ?? 'مدينة غير معروفة',
      temperature: (main['temp'] as num).toDouble() - 273.15,
      feelsLike: (main['feels_like'] as num).toDouble() - 273.15,
      humidity: main['humidity'] ?? 0,
      windSpeed: (wind['speed'] as num?)?.toDouble() ?? 0.0,
      description: weather['description'] ?? 'لا يوجد وصف',
      iconCode: weather['icon'] ?? '01d',
      timestamp: DateTime.now(),
    );
  }
}

// ========== نموذج لتوقعات 5 أيام ==========
class ForecastModel {
  final DateTime date;
  final double temperature;
  final String iconCode;
  final String description;

  ForecastModel({
    required this.date,
    required this.temperature,
    required this.iconCode,
    required this.description,
  });

  factory ForecastModel.fromJson(Map<String, dynamic> json) {
    return ForecastModel(
      date: DateTime.parse(json['dt_txt']),
      temperature: (json['main']['temp'] as num).toDouble() - 273.15,
      iconCode: json['weather'][0]['icon'] ?? '01d',
      description: json['weather'][0]['description'] ?? 'لا يوجد وصف',
    );
  }
}

// ========== الشاشة الأولى: إدخال المدينة ==========
class CityInputScreen extends StatefulWidget {
  const CityInputScreen({super.key});

  @override
  State<CityInputScreen> createState() => _CityInputScreenState();
}

class _CityInputScreenState extends State<CityInputScreen> {
  final TextEditingController _cityController = TextEditingController();
  bool _isLoading = false;
  String _errorMessage = '';

  Future<void> _getWeather() async {
    final city = _cityController.text.trim();
    if (city.isEmpty) {
      setState(() {
        _errorMessage = 'الرجاء إدخال اسم المدينة';
      });
      return;
    }

    setState(() {
      _isLoading = true;
      _errorMessage = '';
    });

    try {
      final apiKey = 'YOUR_API_KEY'; // 🔴 استبدل بمفتاحك
      final url = Uri.parse(
        'https://api.openweathermap.org/data/2.5/weather?q=$city&appid=$apiKey&lang=ar',
      );

      final response = await http.get(url);

      if (response.statusCode == 200) {
        final Map<String, dynamic> jsonData = json.decode(response.body);
        final weather = WeatherModel.fromJson(jsonData);

        // جلب توقعات 5 أيام
        final forecastUrl = Uri.parse(
          'https://api.openweathermap.org/data/2.5/forecast?q=$city&appid=$apiKey&lang=ar',
        );
        final forecastResponse = await http.get(forecastUrl);
        List<ForecastModel> forecast = [];
        if (forecastResponse.statusCode == 200) {
          final forecastData = json.decode(forecastResponse.body);
          final List<dynamic> list = forecastData['list'];
          // نأخذ توقعات كل 24 ساعة (كل 8 عناصر)
          for (int i = 0; i < list.length; i += 8) {
            forecast.add(ForecastModel.fromJson(list[i]));
          }
        }

        if (mounted) {
          Navigator.push(
            context,
            MaterialPageRoute(
              builder: (context) => WeatherDisplayScreen(
                weather: weather,
                forecast: forecast,
              ),
            ),
          );
          _cityController.clear();
          setState(() {
            _isLoading = false;
          });
        }
      } else {
        setState(() {
          _isLoading = false;
          if (response.statusCode == 404) {
            _errorMessage = 'المدينة غير موجودة. تأكد من الاسم.';
          } else if (response.statusCode == 401) {
            _errorMessage = 'مفتاح API غير صحيح. تأكد منه.';
          } else {
            _errorMessage = 'حدث خطأ: ${response.statusCode}';
          }
        });
      }
    } catch (e) {
      setState(() {
        _isLoading = false;
        _errorMessage = 'فشل الاتصال بالإنترنت. تأكد من اتصالك.';
      });
    }
  }

  @override
  void dispose() {
    _cityController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('🌤️ الطقس'),
        backgroundColor: Colors.blue,
        foregroundColor: Colors.white,
      ),
      body: Padding(
        padding: const EdgeInsets.all(24.0),
        child: Center(
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              const Icon(
                Icons.cloud_queue,
                size: 100,
                color: Colors.blue,
              ),
              const SizedBox(height: 24),
              const Text(
                'أدخل اسم المدينة',
                style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
              ),
              const SizedBox(height: 16),
              TextField(
                controller: _cityController,
                decoration: InputDecoration(
                  hintText: 'مثال: Cairo, London, Paris',
                  prefixIcon: const Icon(Icons.location_city),
                  border: OutlineInputBorder(
                    borderRadius: BorderRadius.circular(12),
                  ),
                  errorText: _errorMessage.isNotEmpty ? _errorMessage : null,
                  suffixIcon: _isLoading
                      ? const SizedBox(
                          width: 20,
                          height: 20,
                          child: CircularProgressIndicator(strokeWidth: 2),
                        )
                      : null,
                ),
                textAlign: TextAlign.center,
                textDirection: TextDirection.ltr,
                onSubmitted: (value) => _getWeather(),
              ),
              const SizedBox(height: 20),
              SizedBox(
                width: double.infinity,
                height: 50,
                child: ElevatedButton(
                  onPressed: _isLoading ? null : _getWeather,
                  style: ElevatedButton.styleFrom(
                    backgroundColor: Colors.blue,
                    foregroundColor: Colors.white,
                    shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(12),
                    ),
                  ),
                  child: _isLoading
                      ? const CircularProgressIndicator(
                          color: Colors.white,
                          strokeWidth: 2,
                        )
                      : const Text(
                          '🔍 ابحث عن الطقس',
                          style: TextStyle(fontSize: 18),
                        ),
                ),
              ),
              // ✅ التعديل: زر المدن المفضلة
              const SizedBox(height: 16),
              TextButton.icon(
                onPressed: () {
                  // سيتم تنفيذه لاحقاً
                },
                icon: const Icon(Icons.favorite_border),
                label: const Text('المدن المفضلة'),
              ),
            ],
          ),
        ),
      ),
    );
  }
}

// ========== الشاشة الثانية: عرض الطقس ==========
class WeatherDisplayScreen extends StatefulWidget {
  final WeatherModel weather;
  final List<ForecastModel> forecast;

  const WeatherDisplayScreen({
    super.key,
    required this.weather,
    this.forecast = const [],
  });

  @override
  State<WeatherDisplayScreen> createState() => _WeatherDisplayScreenState();
}

class _WeatherDisplayScreenState extends State<WeatherDisplayScreen>
    with SingleTickerProviderStateMixin {
  late AnimationController _animationController;
  bool _isFavorite = false;

  @override
  void initState() {
    super.initState();
    // ✅ التعديل: حركة الخلفية
    _animationController = AnimationController(
      vsync: this,
      duration: const Duration(seconds: 10),
    )..repeat();
  }

  @override
  void dispose() {
    _animationController.dispose();
    super.dispose();
  }

  IconData _getWeatherIcon(String iconCode) {
    switch (iconCode) {
      case '01d':
      case '01n':
        return Icons.wb_sunny;
      case '02d':
      case '02n':
        return Icons.wb_cloudy;
      case '03d':
      case '03n':
      case '04d':
      case '04n':
        return Icons.cloud;
      case '09d':
      case '09n':
        return Icons.grain;
      case '10d':
      case '10n':
        return Icons.beach_access;
      case '11d':
      case '11n':
        return Icons.flash_on;
      case '13d':
      case '13n':
        return Icons.ac_unit;
      case '50d':
      case '50n':
        return Icons.blur_on;
      default:
        return Icons.cloud_queue;
    }
  }

  // ✅ التعديل: لون الخلفية حسب درجة الحرارة
  Color _getBackgroundColor(double temp) {
    if (temp > 30) return Colors.orange.shade200;
    if (temp > 20) return Colors.blue.shade200;
    if (temp > 10) return Colors.blue.shade300;
    if (temp > 0) return Colors.blue.shade400;
    return Colors.blue.shade900;
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text('🌤️ ${widget.weather.cityName}'),
        backgroundColor: _getBackgroundColor(widget.weather.temperature),
        foregroundColor: Colors.white,
        actions: [
          // ✅ التعديل: زر المفضلة
          IconButton(
            onPressed: () {
              setState(() {
                _isFavorite = !_isFavorite;
              });
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(
                  content: Text(
                    _isFavorite
                        ? 'تمت إضافة ${widget.weather.cityName} إلى المفضلة'
                        : 'تمت إزالة ${widget.weather.cityName} من المفضلة',
                  ),
                  duration: const Duration(seconds: 2),
                ),
              );
            },
            icon: Icon(
              _isFavorite ? Icons.favorite : Icons.favorite_border,
              color: _isFavorite ? Colors.red : Colors.white,
            ),
          ),
          IconButton(
            onPressed: () {
              Navigator.pop(context);
            },
            icon: const Icon(Icons.search),
            tooltip: 'ابحث عن مدينة أخرى',
          ),
        ],
      ),
      body: AnimatedContainer(
        duration: const Duration(milliseconds: 500),
        decoration: BoxDecoration(
          gradient: LinearGradient(
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
            colors: [
              _getBackgroundColor(widget.weather.temperature),
              Colors.white,
            ],
          ),
        ),
        child: SafeArea(
          child: Padding(
            padding: const EdgeInsets.all(24.0),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.center,
              children: [
                // ✅ التعديل: تاريخ ووقت التحديث
                Row(
                  mainAxisAlignment: MainAxisAlignment.spaceBetween,
                  children: [
                    Text(
                      'آخر تحديث: ${widget.weather.timestamp.hour}:${widget.weather.timestamp.minute.toString().padLeft(2, '0')}',
                      style: TextStyle(
                        fontSize: 12,
                        color: Colors.grey.shade600,
                      ),
                    ),
                    // ✅ التعديل: حالة الطقس بالعربي
                    Container(
                      padding: const EdgeInsets.symmetric(
                        horizontal: 12,
                        vertical: 4,
                      ),
                      decoration: BoxDecoration(
                        color: Colors.white.withOpacity(0.3),
                        borderRadius: BorderRadius.circular(20),
                      ),
                      child: Text(
                        widget.weather.description,
                        style: const TextStyle(
                          fontSize: 14,
                          fontWeight: FontWeight.w500,
                        ),
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 20),
                // الأيقونة ودرجة الحرارة
                Row(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    AnimatedBuilder(
                      animation: _animationController,
                      builder: (context, child) {
                        return Transform.rotate(
                          angle: _animationController.value * 0.1,
                          child: Icon(
                            _getWeatherIcon(widget.weather.iconCode),
                            size: 80,
                            color: Colors.blue.shade700,
                          ),
                        );
                      },
                    ),
                    const SizedBox(width: 16),
                    Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          '${widget.weather.temperature.toStringAsFixed(1)}°C',
                          style: const TextStyle(
                            fontSize: 48,
                            fontWeight: FontWeight.bold,
                            color: Colors.blue,
                          ),
                        ),
                        Text(
                          'محسوسة: ${widget.weather.feelsLike.toStringAsFixed(1)}°C',
                          style: TextStyle(
                            fontSize: 16,
                            color: Colors.grey.shade600,
                          ),
                        ),
                      ],
                    ),
                  ],
                ),
                const SizedBox(height: 24),
                // بطاقات التفاصيل
                Row(
                  children: [
                    Expanded(
                      child: _buildDetailCard(
                        icon: Icons.water_drop,
                        label: 'الرطوبة',
                        value: '${widget.weather.humidity}%',
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _buildDetailCard(
                        icon: Icons.air,
                        label: 'الرياح',
                        value: '${widget.weather.windSpeed.toStringAsFixed(1)} m/s',
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 16),
                // ✅ التعديل: توقعات 5 أيام
                if (widget.forecast.isNotEmpty) ...[
                  const Align(
                    alignment: Alignment.centerRight,
                    child: Text(
                      'توقعات 5 أيام:',
                      style: TextStyle(
                        fontSize: 18,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                  ),
                  const SizedBox(height: 8),
                  SizedBox(
                    height: 100,
                    child: ListView.builder(
                      scrollDirection: Axis.horizontal,
                      itemCount: widget.forecast.length,
                      itemBuilder: (context, index) {
                        final forecast = widget.forecast[index];
                        return Container(
                          width: 80,
                          margin: const EdgeInsets.only(right: 8),
                          padding: const EdgeInsets.all(8),
                          decoration: BoxDecoration(
                            color: Colors.white.withOpacity(0.5),
                            borderRadius: BorderRadius.circular(12),
                          ),
                          child: Column(
                            mainAxisAlignment: MainAxisAlignment.center,
                            children: [
                              Text(
                                '${forecast.date.day}/${forecast.date.month}',
                                style: const TextStyle(
                                  fontSize: 12,
                                  fontWeight: FontWeight.bold,
                                ),
                              ),
                              Icon(
                                _getWeatherIcon(forecast.iconCode),
                                size: 30,
                                color: Colors.blue.shade700,
                              ),
                              Text(
                                '${forecast.temperature.toStringAsFixed(0)}°C',
                                style: const TextStyle(
                                  fontSize: 12,
                                  fontWeight: FontWeight.bold,
                                ),
                              ),
                            ],
                          ),
                        );
                      },
                    ),
                  ),
                  const SizedBox(height: 16),
                ],
                const Spacer(),
                // زر العودة
                Row(
                  children: [
                    Expanded(
                      child: OutlinedButton.icon(
                        onPressed: () {
                          Navigator.pop(context);
                        },
                        icon: const Icon(Icons.arrow_back),
                        label: const Text('بحث عن مدينة أخرى'),
                        style: OutlinedButton.styleFrom(
                          padding: const EdgeInsets.all(16),
                          side: BorderSide(color: Colors.blue.shade300),
                        ),
                      ),
                    ),
                    // ✅ التعديل: زر مشاركة الطقس
                    const SizedBox(width: 12),
                    CircleAvatar(
                      backgroundColor: Colors.blue.shade100,
                      child: IconButton(
                        onPressed: () {
                          ScaffoldMessenger.of(context).showSnackBar(
                            const SnackBar(
                              content: Text('📤 تم نسخ معلومات الطقس'),
                              duration: Duration(seconds: 2),
                            ),
                          );
                        },
                        icon: Icon(
                          Icons.share,
                          color: Colors.blue.shade700,
                        ),
                      ),
                    ),
                  ],
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildDetailCard({
    required IconData icon,
    required String label,
    required String value,
  }) {
    return Card(
      elevation: 4,
      shape: RoundedRectangleBorder(
        borderRadius: BorderRadius.circular(16),
      ),
      child: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          children: [
            Icon(icon, size: 30, color: Colors.blue.shade700),
            const SizedBox(height: 8),
            Text(
              value,
              style: const TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
              ),
            ),
            Text(
              label,
              style: TextStyle(
                fontSize: 14,
                color: Colors.grey.shade600,
              ),
            ),
          ],
        ),
      ),
    );
  }
}
