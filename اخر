DB_PATH = Path("ucl_database.db")

# ---------- قاعدة البيانات ----------
def init_db():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS teams (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT UNIQUE NOT NULL,
        country TEXT,
        group_char TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS matches (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        home_team TEXT,
        away_team TEXT,
        home_goals INTEGER,
        away_goals INTEGER,
        date TEXT,
        stage TEXT
    )''')
    conn.commit()
    conn.close()

def add_team(name, country, group):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("INSERT INTO teams (name, country, group_char) VALUES (?, ?, ?)", (name, country, group))
        conn.commit()
        return True
    except sqlite3.IntegrityError:
        return False
    finally:
        conn.close()

def add_match(home, away, hg, ag, date, stage):
    # تحقق من عدم وجود مباراة ذهاب/إياب مكررة في مراحل الإقصائيات
    if stage in ["Round of 16", "Quarter Final", "Semi Final", "Final"]:
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute("""SELECT COUNT(*) FROM matches 
                     WHERE stage=? AND ((home_team=? AND away_team=?) OR (home_team=? AND away_team=?))""",
                  (stage, home, away, away, home))
        count = c.fetchone()[0]
        conn.close()
        if count > 0:
            return False, "مباراة ذهاب أو إياب موجودة مسبقاً في هذه المرحلة"  # رسالة الخطأ
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("""INSERT INTO matches (home_team, away_team, home_goals, away_goals, date, stage)
                 VALUES (?, ?, ?, ?, ?, ?)""", (home, away, hg, ag, date, stage))
    conn.commit()
    conn.close()
    return True, "تمت الإضافة"

def get_teams():
    conn = sqlite3.connect(DB_PATH)
    df = pd.read_sql_query("SELECT name FROM teams ORDER BY name", conn)
    conn.close()
    return df["name"].tolist()

def get_standings():
    conn = sqlite3.connect(DB_PATH)
    query = """
    SELECT t.name,
           COUNT(m.id) AS P,
           SUM(CASE WHEN (m.home_team = t.name AND m.home_goals > m.away_goals) OR 
                         (m.away_team = t.name AND m.away_goals > m.home_goals) THEN 1 ELSE 0 END) AS W,
           SUM(CASE WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS D,
           SUM(CASE WHEN (m.home_team = t.name AND m.home_goals < m.away_goals) OR 
                         (m.away_team = t.name AND m.away_goals < m.home_goals) THEN 1 ELSE 0 END) AS L,
           COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.home_goals ELSE m.away_goals END), 0) AS GF,
           COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.away_goals ELSE m.home_goals END), 0) AS GA,
           (COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.home_goals ELSE m.away_goals END), 0) -
            COALESCE(SUM(CASE WHEN m.home_team = t.name THEN m.away_goals ELSE m.home_goals END), 0)) AS GD,
           SUM(CASE WHEN (m.home_team = t.name AND m.home_goals > m.away_goals) OR 
                        (m.away_team = t.name AND m.away_goals > m.home_goals) THEN 3
                WHEN m.home_goals = m.away_goals AND m.home_goals IS NOT NULL THEN 1 ELSE 0 END) AS Pts
    FROM teams t LEFT JOIN matches m ON m.home_team = t.name OR m.away_team = t.name
    GROUP BY t.name
    ORDER BY Pts DESC, GD DESC, GF DESC
    """
    df = pd.read_sql_query(query, conn)
    conn.close()
    return df

def get_matches(stage=None):
    conn = sqlite3.connect(DB_PATH)
    if stage:
        df = pd.read_sql_query("SELECT * FROM matches WHERE stage = ? ORDER BY date", conn, params=(stage,))
    else:
        df = pd.read_sql_query("SELECT * FROM matches ORDER BY date", conn)
    conn.close()
    return df

def delete_all_matches(stage=None):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    if stage:
        c.execute("DELETE FROM matches WHERE stage=?", (stage,))
    else:
        c.execute("DELETE FROM matches")
    conn.commit()
    conn.close()

