    def populate_knockouts_table(self):
        stage = self.k_stage_combo.currentText()
        df = get_matches(stage)
        self.k_table.setColumnCount(4)
        headers = ["المضيف","الضيف","أهداف المضيف","أهداف الضيف"] if self.lang=="ar" else ["Home","Away","Home Goals","Away Goals"]
        self.k_table.setHorizontalHeaderLabels(headers)
        self.k_table.setRowCount(len(df))
        for i, row in df.iterrows():
            for j, key in enumerate(["home_team","away_team","home_goals","away_goals"]):
                self.k_table.setItem(i, j, QTableWidgetItem(str(row[key])))
        self.k_table.resizeColumnsToContents()

    def generate_knockout_matches(self):
        stage = self.k_stage_combo.currentText()
        # الحصول على الفرق المتأهلة بناء على النقاط
        standings = get_standings()
        qualified = standings[standings["Pts"] > 0]["name"].tolist()  # يمكن تعديل قاعدة التأهل حسب دوري الأبطال
        random.shuffle(qualified)
        matches = []
        while len(qualified) >=2:
            home = qualified.pop()
            away = qualified.pop()
            matches.append((home, away))
        # إضافة إلى قاعدة البيانات مع التحقق من الذهاب والإياب
        for home, away in matches:
            add_match(home, away, 0, 0, QDate.currentDate().toString("yyyy-MM-dd"), stage)
        self.populate_knockouts_table()
        QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", "تم توليد المباريات بنجاح" if self.lang=="ar" else "Matches generated")

    def advance_to_next_round(self):
        stage_order = ["Round of 16", "Quarter Final", "Semi Final", "Final"]
        current_stage = self.k_stage_combo.currentText()
        try:
            idx = stage_order.index(current_stage)
        except ValueError:
            QMessageBox.warning(self, "خطأ" if self.lang=="ar" else "Error", "اختر جولة صحيحة" if self.lang=="ar" else "Select a valid stage")
            return
        df = get_matches(current_stage)
        winners = []
        for i, row in df.iterrows():
            if row["home_goals"] > row["away_goals"]:
                winners.append(row["home_team"])
            elif row["away_goals"] > row["home_goals"]:
                winners.append(row["away_team"])
            else:
                # في حالة التعادل، اختيار عشوائي للفائز (يمكن تعديل ليكون بالنظام الفعلي)
                winners.append(random.choice([row["home_team"], row["away_team"]]))
        if idx+1 >= len(stage_order):
            QMessageBox.information(self, "نهائي" if self.lang=="ar" else "Final", "تم الانتهاء من النهائي" if self.lang=="ar" else "Final completed")
            return
        next_stage = stage_order[idx+1]
        random.shuffle(winners)
        # حذف المباريات السابقة من الدور التالي إذا وجدت
        delete_all_matches(next_stage)
        while len(winners)>=2:
            home = winners.pop()
            away = winners.pop()
            add_match(home, away, 0, 0, QDate.currentDate().toString("yyyy-MM-dd"), next_stage)
        self.k_stage_combo.setCurrentText(next_stage)
        self.populate_knockouts_table()
        QMessageBox.information(self, "تم" if self.lang=="ar" else "Done", f"تم الانتقال إلى {next_stage}" if self.lang=="ar" else f"Advanced to {next_stage}")

